{
  "name": "@agura/es-client",
  "version": "0.1.0",
  "description": "ElementStore client — AtomObj, AtomCollection, AtomStorage, ActionExecutor and supporting modules",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "build:browser": "tsup --config tsup.config.ts --entry.element-store src/browser.ts",
    "dev": "tsup --watch"
  },
  "publishConfig": {
    "registry": "https://git.agura.tech/api/v4/projects/123/packages/npm/",
    "access": "restricted"
  },
  "peerDependencies": {
    "react": ">=17",
    "lucide-react": ">=0.300"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    }
  },
  "keywords": [
    "elementstore",
    "atomobj",
    "client"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/react": "^19.2.0",
    "lucide-react": "^0.562.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
