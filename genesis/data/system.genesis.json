{
  "version": "2.0.0",
  "description": "ElementStore system class definitions — the meta-schema that defines how ElementStore works",
  "classes": [
    {
      "id": "@class",
      "class_id": "@class",
      "name": "Class",
      "description": "Defines a data class with its properties and behaviors",
      "is_system": true,
      "props": [
        {"key": "name",        "label": "Name",        "description": "Display name of the class",                                    "data_type": "string",   "required": true,  "display_order": 1},
        {"key": "description", "label": "Description", "description": "What this class represents",                                   "data_type": "string",   "editor": "textarea", "display_order": 2},
        {"key": "extends_id",  "label": "Extends",     "description": "Parent class for inheritance",                                 "data_type": "relation", "object_class_id": ["@class"], "create_only": true, "display_order": 3},
        {"key": "props",       "label": "Properties",  "description": "Property definitions for this class",                         "data_type": "object",   "is_array": true, "object_class_id": ["@prop"], "display_order": 4},
        {"key": "table_name",  "label": "Table Name",  "description": "Custom table/collection name for storage",                    "data_type": "string",   "display_order": 5, "group_name": "Advanced"},
        {"key": "storage_id",  "label": "Storage",     "description": "Storage provider (falls back to parent class, then default)", "data_type": "relation", "object_class_id": ["@storage"], "display_order": 6, "group_name": "Advanced"},
        {"key": "is_system",   "label": "System Class","description": "Protected system class (cannot be deleted)",                  "data_type": "boolean",  "readonly": true, "default_value": false, "display_order": 7, "group_name": "Advanced"},
        {"key": "is_abstract", "label": "Abstract",    "description": "Cannot create instances directly (only via child classes)",   "data_type": "boolean",  "default_value": false, "display_order": 8, "group_name": "Advanced"},
        {"key": "providers",   "label": "Providers",   "description": "Data providers for external API integration",                 "data_type": "relation", "is_array": true, "object_class_id": ["@provider"], "display_order": 9, "group_name": "Advanced"}
      ]
    },
    {
      "id": "@prop",
      "class_id": "@class",
      "name": "Property",
      "description": "Defines a property within a class — type, validation, and UI behavior",
      "is_system": true,
      "props": [
        {"key": "data_type",           "label": "Data Type",     "description": "Type of value this property holds",                       "data_type": "string",   "required": true, "default_value": "string", "options": {"type": "string_options", "values": ["string","boolean","integer","float","datetime","object","relation","function"]}, "display_order": 1, "group_name": "Type"},
        {"key": "is_array",            "label": "Is Array",      "description": "Property holds multiple values",                          "data_type": "boolean",  "default_value": false, "display_order": 2, "group_name": "Type"},
        {"key": "key",                 "label": "Key",           "description": "Property key (field name in data)",                       "data_type": "string",   "required": true, "display_order": 10, "group_name": "Core"},
        {"key": "label",               "label": "Label",         "description": "Display label in UI",                                     "data_type": "string",   "display_order": 11, "group_name": "Core"},
        {"key": "description",         "label": "Description",   "description": "Help text shown to users",                               "data_type": "string",   "editor": "textarea", "display_order": 12, "group_name": "Core"},
        {"key": "options",             "label": "Type Options",  "description": "Type-specific options (varies by data_type)",             "data_type": "object",   "display_order": 20, "group_name": "Options"},
        {"key": "object_class_id",     "label": "Target Classes","description": "Class IDs for relations/embedded objects",               "data_type": "string",   "is_array": true, "display_order": 30, "group_name": "Relation"},
        {"key": "object_class_strict", "label": "Strict Class",  "description": "Only accept exact class, not child classes",             "data_type": "boolean",  "default_value": false, "display_order": 31, "group_name": "Relation"},
        {"key": "on_orphan",           "label": "On Orphan",     "description": "Action when referenced object is deleted",               "data_type": "string",   "options": {"type": "string_options", "values": ["keep","delete","nullify"]}, "default_value": "keep", "display_order": 32, "group_name": "Relation"},
        {"key": "editor",              "label": "Editor",        "description": "UI editor — relation to @editor instance",               "data_type": "relation", "object_class_id": ["@editor"], "display_order": 40, "group_name": "UI"},
        {"key": "field_type",          "label": "Field Type",    "description": "Shorthand field type string (e.g. email, url, textarea)", "data_type": "string",   "display_order": 41, "group_name": "UI"},
        {"key": "display_order",       "label": "Display Order", "description": "Sort order in forms (lower = first)",                    "data_type": "integer",  "default_value": 0, "display_order": 42, "group_name": "UI"},
        {"key": "group_name",          "label": "Group",         "description": "Form section grouping",                                  "data_type": "string",   "display_order": 43, "group_name": "UI"},
        {"key": "hidden",              "label": "Hidden",        "description": "Hide from default UI views",                             "data_type": "boolean",  "default_value": false, "display_order": 44, "group_name": "UI"},
        {"key": "required",            "label": "Required",      "description": "Field must have a value",                                "data_type": "boolean",  "default_value": false, "display_order": 50, "group_name": "Validation"},
        {"key": "readonly",            "label": "Read Only",     "description": "Field cannot be edited after creation",                  "data_type": "boolean",  "default_value": false, "display_order": 51, "group_name": "Validation"},
        {"key": "create_only",         "label": "Create Only",   "description": "Only writable when creating new objects",                "data_type": "boolean",  "default_value": false, "display_order": 52, "group_name": "Validation"},
        {"key": "default_value",       "label": "Default Value", "description": "Default value for new objects",                         "data_type": "string",   "display_order": 53, "group_name": "Validation"},
        {"key": "validators",          "label": "Validators",    "description": "Validation rules — relation to @function instances",     "data_type": "relation", "object_class_id": ["@function"], "is_array": true, "display_order": 54, "group_name": "Validation"},
        {"key": "server_only",         "label": "Server Only",   "description": "Stripped from API responses (backend-only)",            "data_type": "boolean",  "default_value": false, "display_order": 60, "group_name": "Security"},
        {"key": "master_only",         "label": "Master Only",   "description": "Only visible on master/admin interface",                 "data_type": "boolean",  "default_value": false, "display_order": 61, "group_name": "Security"}
      ]
    },
    {
      "id": "@editor",
      "class_id": "@class",
      "name": "Editor",
      "description": "Defines a UI editor component for editing property values. Instances are seed data (text, textarea, select, etc.)",
      "is_system": true,
      "props": [
        {"key": "name",       "label": "Name",         "description": "Editor display name",                            "data_type": "string",  "required": true, "display_order": 1},
        {"key": "description","label": "Description",  "description": "What this editor is for",                       "data_type": "string",  "editor": "textarea", "display_order": 2},
        {"key": "data_types", "label": "Data Types",   "description": "Supported data types",                          "data_type": "string",  "is_array": true, "required": true, "options": {"type": "string_options", "values": ["string","boolean","integer","float","datetime","object","relation","function"]}, "display_order": 3},
        {"key": "is_default", "label": "Default",      "description": "Default editor for its data types",             "data_type": "boolean", "default_value": false, "display_order": 4},
        {"key": "is_system",  "label": "System Editor","description": "Protected system editor (cannot be deleted)",   "data_type": "boolean", "readonly": true, "default_value": false, "display_order": 5},
        {"key": "validator",  "label": "Validator",    "description": "Built-in validator (e.g. email, url, phone)",   "data_type": "string",  "display_order": 6},
        {"key": "props",      "label": "Options Schema","description": "Configuration options this editor accepts",    "data_type": "object",  "is_array": true, "object_class_id": ["@prop"], "display_order": 7},
        {"key": "component",  "label": "Component",    "description": "UI component name or path",                     "data_type": "string",  "display_order": 8},
        {"key": "render",     "label": "Render",       "description": "Custom render function: (scope) => html",       "data_type": "function","editor": "javascript", "display_order": 9}
      ]
    },
    {
      "id": "@storage",
      "class_id": "@class",
      "name": "Storage",
      "description": "Storage provider configuration — defines where and how class data is persisted",
      "is_system": true,
      "props": [
        {"key": "name", "label": "Name", "description": "Storage provider display name", "data_type": "string", "required": true, "display_order": 1},
        {"key": "url",  "label": "URL",  "description": "API endpoint URL for this storage provider", "data_type": "string", "field_type": "url", "display_order": 2},
        {"key": "type", "label": "Type", "description": "Storage provider type", "data_type": "string", "options": {"type": "string_options", "values": ["local","rest","couchdb","mysql","json"]}, "default_value": "rest", "display_order": 3}
      ]
    },
    {
      "id": "@function",
      "class_id": "@class",
      "name": "Function",
      "description": "Defines a reusable function — validators, transformers, generators, or computed fields",
      "is_system": true,
      "props": [
        {"key": "name",          "label": "Name",          "description": "Function display name",                                                "data_type": "string",   "required": true, "display_order": 1},
        {"key": "description",   "label": "Description",   "description": "What this function does",                                              "data_type": "string",   "editor": "textarea", "display_order": 2},
        {"key": "function_type", "label": "Function Type", "description": "Category of function",                                                 "data_type": "string",   "required": true, "options": {"type": "string_options", "values": ["validator","transformer","computed","generator","custom"]}, "display_order": 3},
        {"key": "scope",         "label": "Scope",         "description": "Which data types this function applies to",                            "data_type": "string",   "is_array": true, "display_order": 4},
        {"key": "parameters",    "label": "Parameters",    "description": "Function input parameters schema",                                     "data_type": "object",   "is_array": true, "object_class_id": ["@prop"], "display_order": 5},
        {"key": "code",          "label": "Code",          "description": "JavaScript: (obj, prop, value, params) => result",                    "data_type": "function", "editor": "javascript", "required": true, "display_order": 6},
        {"key": "is_system",     "label": "System",        "description": "Protected system function",                                           "data_type": "boolean",  "readonly": true, "default_value": false, "display_order": 7}
      ]
    },
    {
      "id": "@action",
      "class_id": "@class",
      "name": "Action",
      "description": "Defines an executable action that can be triggered on objects",
      "is_system": true,
      "props": [
        {"key": "name",               "label": "Name",              "description": "Action display name",                           "data_type": "string",   "required": true, "display_order": 1},
        {"key": "description",        "label": "Description",       "description": "What this action does",                        "data_type": "string",   "editor": "textarea", "display_order": 2},
        {"key": "target_class_id",    "label": "Target Class",      "description": "Class this action applies to",                 "data_type": "relation", "object_class_id": ["@class"], "display_order": 3},
        {"key": "handler",            "label": "Handler",           "description": "Action implementation: (scope) => result",     "data_type": "function", "editor": "javascript", "required": true, "display_order": 4},
        {"key": "params",             "label": "Parameters",        "description": "Action input parameters",                      "data_type": "object",   "is_array": true, "object_class_id": ["@prop"], "display_order": 5},
        {"key": "returns",            "label": "Returns",           "description": "Return type description",                      "data_type": "object",   "object_class_id": ["@prop"], "display_order": 6},
        {"key": "requires_selection", "label": "Requires Selection","description": "Action requires selected object(s)",           "data_type": "boolean",  "default_value": true, "display_order": 7},
        {"key": "bulk",               "label": "Bulk Action",       "description": "Can apply to multiple objects",               "data_type": "boolean",  "default_value": false, "display_order": 8},
        {"key": "confirm",            "label": "Confirm",           "description": "Confirmation message (empty = no confirm)",   "data_type": "string",   "display_order": 9},
        {"key": "icon",               "label": "Icon",              "description": "Icon name for UI",                            "data_type": "string",   "display_order": 10}
      ]
    },
    {
      "id": "@event",
      "class_id": "@class",
      "name": "Event",
      "description": "Defines an event that can be subscribed to and triggered",
      "is_system": true,
      "props": [
        {"key": "name",           "label": "Name",           "description": "Event name",                                                "data_type": "string",   "required": true, "display_order": 1},
        {"key": "description",    "label": "Description",    "description": "What triggers this event",                                 "data_type": "string",   "editor": "textarea", "display_order": 2},
        {"key": "target_class_id","label": "Target Class",   "description": "Class this event applies to",                             "data_type": "relation", "object_class_id": ["@class"], "display_order": 3},
        {"key": "trigger",        "label": "Trigger",        "description": "When this event fires",                                    "data_type": "string",   "options": {"type": "string_options", "values": ["before_create","after_create","before_update","after_update","before_delete","after_delete","on_change","custom"]}, "display_order": 4},
        {"key": "handler",        "label": "Handler",        "description": "Event handler: (scope) => void",                          "data_type": "function", "editor": "javascript", "required": true, "display_order": 5},
        {"key": "payload_schema", "label": "Payload Schema", "description": "Event payload structure",                                 "data_type": "object",   "is_array": true, "object_class_id": ["@prop"], "display_order": 6},
        {"key": "async",          "label": "Async",          "description": "Run handler asynchronously",                              "data_type": "boolean",  "default_value": false, "display_order": 7},
        {"key": "priority",       "label": "Priority",       "description": "Execution order (higher = first)",                        "data_type": "integer",  "default_value": 0, "display_order": 8}
      ]
    },
    {
      "id": "@provider",
      "class_id": "@class",
      "name": "Provider",
      "description": "Abstract base for data providers — defines how to fetch/save data via external APIs",
      "is_system": true,
      "is_abstract": true,
      "props": [
        {"key": "name",          "label": "Name",                "description": "Provider display name",                           "data_type": "string", "required": true, "display_order": 1},
        {"key": "description",   "label": "Description",         "description": "What this provider connects to",                  "data_type": "string", "editor": "textarea", "display_order": 2},
        {"key": "provider_type", "label": "Provider Type",       "description": "Type of provider (crud, graphql, etc.)",         "data_type": "string", "display_order": 3},
        {"key": "base_url",      "label": "Base URL",            "description": "Base URL for API requests",                       "data_type": "string", "display_order": 4},
        {"key": "auth",          "label": "Authentication",      "description": "Authentication configuration",                    "data_type": "object", "display_order": 5},
        {"key": "params",        "label": "Default Parameters",  "description": "Default query parameters for every request",     "data_type": "object", "display_order": 6}
      ]
    },
    {
      "id": "crud_provider",
      "class_id": "@class",
      "extends_id": "@provider",
      "name": "CRUD Provider",
      "description": "Provider for standard CRUD operations — URLs, pagination, filters, and field mapping",
      "is_system": true,
      "props": [
        {"key": "get_one",    "label": "Get One",        "description": "URL pattern for fetching one object",    "data_type": "string", "display_order": 10},
        {"key": "get_list",   "label": "Get List",       "description": "URL pattern for listing objects",       "data_type": "string", "display_order": 11},
        {"key": "create_one", "label": "Create One",     "description": "URL pattern for creating an object",    "data_type": "string", "display_order": 12},
        {"key": "update_one", "label": "Update One",     "description": "URL pattern for updating an object",    "data_type": "string", "display_order": 13},
        {"key": "delete_one", "label": "Delete One",     "description": "URL pattern for deleting an object",    "data_type": "string", "display_order": 14},
        {"key": "paginator",  "label": "Paginator",      "description": "Pagination configuration",              "data_type": "object", "display_order": 15},
        {"key": "filters",    "label": "Filters",        "description": "Available filter parameter names",      "data_type": "string", "is_array": true, "display_order": 16},
        {"key": "mapping",    "label": "Field Mapping",  "description": "ES_key → API_field (string or @function transform)", "data_type": "object", "display_order": 17}
      ]
    }
  ,
    {
      "id": "auth_config",
      "class_id": "@class",
      "name": "Auth Config",
      "description": "Auth-service connection configuration for this elementStore installation. One object per installation. All endpoint paths are configurable here.",
      "is_system": true,
      "props": [
        {"key": "app_id",               "label": "App ID",                "description": "Identifier for this app in the auth-service (e.g. 'elementStore')",         "data_type": "string",   "required": true,  "create_only": true, "display_order": 1,  "group_name": "Identity"},
        {"key": "app_name",             "label": "App Name",              "description": "Human-readable display name registered in auth-service",                    "data_type": "string",   "required": true,              "display_order": 2,  "group_name": "Identity"},
        {"key": "service_url",          "label": "Auth Service URL",      "description": "Base URL of the auth-service (e.g. http://agura-auth:3100)",               "data_type": "string",   "required": true,  "field_type": "url", "display_order": 3,  "group_name": "Connection"},
        {"key": "is_enabled",           "label": "Enabled",               "description": "Enable auth enforcement on all API requests",                              "data_type": "boolean",  "default_value": true,                          "display_order": 4,  "group_name": "Connection"},
        {"key": "scopes",               "label": "Scopes",                "description": "Permission scopes this app requests (e.g. read, write, admin)",            "data_type": "string",   "is_array": true,              "display_order": 5,  "group_name": "Identity"},
        {"key": "allowed_origins",      "label": "Allowed Origins",       "description": "Browser origins allowed to use tokens issued for this app",                "data_type": "string",   "is_array": true,              "display_order": 6,  "group_name": "Identity"},

        {"key": "ep_login",             "label": "Login Endpoint",        "description": "POST — authenticate user, returns JWT",                                    "data_type": "string",   "default_value": "/api/auth/login",                         "display_order": 20, "group_name": "Endpoints"},
        {"key": "ep_logout",            "label": "Logout Endpoint",       "description": "POST — invalidate token",                                                  "data_type": "string",   "default_value": "/api/auth/logout",                        "display_order": 21, "group_name": "Endpoints"},
        {"key": "ep_verify",            "label": "Verify Endpoint",       "description": "GET — verify a token (remote check, optional)",                            "data_type": "string",   "default_value": "/api/auth/verify",                        "display_order": 22, "group_name": "Endpoints"},
        {"key": "ep_refresh",           "label": "Refresh Endpoint",      "description": "POST — refresh an expiring JWT",                                           "data_type": "string",   "default_value": "/api/auth/refresh",                       "display_order": 23, "group_name": "Endpoints"},
        {"key": "ep_jwks",              "label": "JWKS Endpoint",         "description": "GET — fetch public keys for local JWT verification",                       "data_type": "string",   "default_value": "/.well-known/jwks.json",                  "display_order": 24, "group_name": "Endpoints"},
        {"key": "ep_register_app",      "label": "Register App Endpoint", "description": "POST — register this app with auth-service on first boot",                "data_type": "string",   "default_value": "/api/auth/apps",                          "display_order": 25, "group_name": "Endpoints"},
        {"key": "ep_get_app",           "label": "Get App Endpoint",      "description": "GET — check if app is already registered (appended with /{app_id})",      "data_type": "string",   "default_value": "/api/auth/apps",                          "display_order": 26, "group_name": "Endpoints"},
        {"key": "ep_register_machine",  "label": "Register Machine",      "description": "POST — register this machine/instance (appended with /{app_id}/machines)","data_type": "string",   "default_value": "/api/auth/apps",                          "display_order": 27, "group_name": "Endpoints"},
        {"key": "ep_list_machines",     "label": "List Machines",         "description": "GET — list registered machines for this app",                             "data_type": "string",   "default_value": "/api/auth/apps",                          "display_order": 28, "group_name": "Endpoints"},
        {"key": "ep_revoke_machine",    "label": "Revoke Machine",        "description": "DELETE — revoke a specific machine registration",                         "data_type": "string",   "default_value": "/api/auth/apps",                          "display_order": 29, "group_name": "Endpoints"},

        {"key": "public_key",           "label": "Public Key (cached)",   "description": "Cached JWT public key fetched from JWKS endpoint at boot",                "data_type": "string",   "server_only": true, "readonly": true,   "display_order": 40, "group_name": "Keys"},
        {"key": "public_key_kid",       "label": "Key ID (kid)",          "description": "Key identifier from JWKS — used to select key for verification",          "data_type": "string",   "server_only": true, "readonly": true,   "display_order": 41, "group_name": "Keys"},
        {"key": "public_key_fetched_at","label": "Key Fetched At",        "description": "When the public key was last fetched from auth-service",                  "data_type": "string",   "server_only": true, "readonly": true,   "display_order": 42, "group_name": "Keys"}
      ]
    },
    {
      "id": "auth_app",
      "class_id": "@class",
      "name": "Auth App Registration",
      "description": "Credentials returned after registering this app with auth-service. One object per app_id. client_secret is server_only.",
      "is_system": true,
      "props": [
        {"key": "config_id",      "label": "Auth Config",    "description": "Auth config this registration belongs to",              "data_type": "relation", "object_class_id": ["auth_config"], "required": true,  "create_only": true, "display_order": 1},
        {"key": "client_id",      "label": "Client ID",      "description": "Client ID assigned by auth-service after registration", "data_type": "string",   "required": true,  "readonly": true,    "display_order": 2},
        {"key": "client_secret",  "label": "Client Secret",  "description": "Client secret — never exposed via API",                "data_type": "string",   "required": true,  "server_only": true, "display_order": 3},
        {"key": "registered_at",  "label": "Registered At",  "description": "When this app was first registered",                   "data_type": "string",   "readonly": true,  "display_order": 4},
        {"key": "is_active",      "label": "Active",         "description": "Whether this registration is currently valid",          "data_type": "boolean",  "default_value": true,               "display_order": 5}
      ]
    },
    {
      "id": "auth_machine",
      "class_id": "@class",
      "name": "Auth Machine",
      "description": "Per-instance machine registration with auth-service. One object created/updated on each elementStore boot.",
      "is_system": true,
      "props": [
        {"key": "config_id",      "label": "Auth Config",     "description": "Auth config this machine belongs to",                                   "data_type": "relation", "object_class_id": ["auth_config"], "required": true,  "create_only": true, "display_order": 1},
        {"key": "instance_id",    "label": "Instance ID",     "description": "UUID generated once for this machine, persists across reboots",         "data_type": "string",   "required": true,  "create_only": true, "display_order": 2},
        {"key": "machine_id",     "label": "Machine ID",      "description": "Machine ID returned by auth-service after registration",                "data_type": "string",   "readonly": true,                   "display_order": 3},
        {"key": "hostname",       "label": "Hostname",        "description": "Hostname of this machine at time of registration",                      "data_type": "string",   "readonly": true,                   "display_order": 4},
        {"key": "ip",             "label": "IP Address",      "description": "IP address of this machine at time of registration",                    "data_type": "string",   "readonly": true,                   "display_order": 5},
        {"key": "version",        "label": "ES Version",      "description": "ElementStore version running on this machine",                          "data_type": "string",   "readonly": true,                   "display_order": 6},
        {"key": "registered_at",  "label": "Registered At",   "description": "When this machine was first registered",                               "data_type": "string",   "readonly": true,                   "display_order": 7},
        {"key": "last_boot_at",   "label": "Last Boot At",    "description": "Timestamp of the last successful boot registration",                   "data_type": "string",   "readonly": true,                   "display_order": 8},
        {"key": "is_active",      "label": "Active",          "description": "Whether this machine is currently authorized",                          "data_type": "boolean",  "default_value": true,              "display_order": 9}
      ]
    }
  ]
}
