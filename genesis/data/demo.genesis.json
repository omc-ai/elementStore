{
  "version": "1.0.0",
  "namespace": "demo",
  "description": "Demo tenant seed data for arc3d.ai — pre-loaded classes and objects visitors can explore.",
  "classes": [
    {
      "id": "demo:server",
      "class_id": "@class",
      "name": "Server",
      "namespace_id": "demo",
      "description": "A cloud or bare-metal server with live metrics",
      "icon": "server",
      "color": "#3b82f6",
      "props": [
        { "key": "ip",        "data_type": "string",  "description": "IP address",           "display_order": 0 },
        { "key": "status",    "data_type": "string",  "description": "running | stopped | rebooting", "display_order": 1,
          "options": { "values": ["running", "stopped", "rebooting", "maintenance"] } },
        { "key": "cpu_usage", "data_type": "float",   "description": "CPU usage %",          "display_order": 2 },
        { "key": "ram_usage", "data_type": "float",   "description": "RAM usage %",          "display_order": 3 },
        { "key": "region",    "data_type": "string",  "description": "Cloud region",         "display_order": 4,
          "options": { "values": ["us-east-1", "us-west-2", "eu-west-1", "ap-southeast-1"] } },
        { "key": "type",      "data_type": "string",  "description": "Instance type",        "display_order": 5,
          "options": { "values": ["t3.micro", "t3.small", "t3.medium", "c5.large", "m5.xlarge"] } },
        { "key": "tags",      "data_type": "string",  "description": "Comma-separated tags", "display_order": 6, "is_array": "indexed" }
      ]
    },
    {
      "id": "demo:project",
      "class_id": "@class",
      "name": "Project",
      "namespace_id": "demo",
      "description": "Software project with team and milestones",
      "icon": "folder",
      "color": "#10b981",
      "props": [
        { "key": "status",      "data_type": "string",  "description": "active | paused | done | archived", "display_order": 0,
          "options": { "values": ["active", "paused", "done", "archived"] } },
        { "key": "owner",       "data_type": "string",  "description": "Project owner",     "display_order": 1 },
        { "key": "team",        "data_type": "string",  "description": "Team members",      "display_order": 2, "is_array": "indexed" },
        { "key": "deadline",    "data_type": "datetime","description": "Target completion", "display_order": 3 },
        { "key": "progress",    "data_type": "integer", "description": "Completion %",      "display_order": 4 },
        { "key": "priority",    "data_type": "string",  "description": "P0 | P1 | P2 | P3","display_order": 5,
          "options": { "values": ["P0", "P1", "P2", "P3"] } },
        { "key": "description", "data_type": "string",  "description": "Project overview",  "display_order": 6 },
        { "key": "repo_url",    "data_type": "string",  "description": "Git repository URL","display_order": 7 }
      ]
    },
    {
      "id": "demo:task",
      "class_id": "@class",
      "name": "Ticket",
      "namespace_id": "demo",
      "description": "Work item assigned to a team member",
      "icon": "check-square",
      "color": "#f59e0b",
      "props": [
        { "key": "status",      "data_type": "string",  "description": "open | in_progress | review | done | blocked", "display_order": 0,
          "options": { "values": ["open", "in_progress", "review", "done", "blocked"] } },
        { "key": "assignee",    "data_type": "string",  "description": "Assigned to",       "display_order": 1 },
        { "key": "project_id",  "data_type": "string",  "description": "Parent project ID", "display_order": 2 },
        { "key": "priority",    "data_type": "string",  "description": "P0 | P1 | P2 | P3","display_order": 3,
          "options": { "values": ["P0", "P1", "P2", "P3"] } },
        { "key": "estimate_h",  "data_type": "float",   "description": "Estimated hours",   "display_order": 4 },
        { "key": "labels",      "data_type": "string",  "description": "Labels",            "display_order": 5, "is_array": "indexed" },
        { "key": "description", "data_type": "string",  "description": "Task details",      "display_order": 6 }
      ]
    },
    {
      "id": "demo:team_member",
      "class_id": "@class",
      "name": "Team Member",
      "namespace_id": "demo",
      "description": "A person on the engineering team",
      "icon": "user",
      "color": "#8b5cf6",
      "props": [
        { "key": "email",    "data_type": "string", "description": "Work email",     "display_order": 0 },
        { "key": "role",     "data_type": "string", "description": "Job title/role", "display_order": 1,
          "options": { "values": ["CTO", "Backend Engineer", "Frontend Engineer", "DevOps", "Designer", "Product Manager", "QA Engineer"] } },
        { "key": "team",     "data_type": "string", "description": "Team name",      "display_order": 2,
          "options": { "values": ["Platform", "Frontend", "Backend", "Infrastructure", "Product"] } },
        { "key": "timezone", "data_type": "string", "description": "Timezone",       "display_order": 3,
          "options": { "values": ["UTC", "UTC+2", "UTC-5", "UTC-8", "UTC+8"] } },
        { "key": "skills",   "data_type": "string", "description": "Technical skills","display_order": 4, "is_array": "indexed" },
        { "key": "active",   "data_type": "boolean","description": "Active employee","display_order": 5 }
      ]
    },
    {
      "id": "demo:environment",
      "class_id": "@class",
      "name": "Environment",
      "namespace_id": "demo",
      "description": "Deployment environment (dev, staging, production)",
      "icon": "layers",
      "color": "#ef4444",
      "props": [
        { "key": "type",        "data_type": "string",  "description": "development | staging | production", "display_order": 0,
          "options": { "values": ["development", "staging", "production"] } },
        { "key": "url",         "data_type": "string",  "description": "Base URL",           "display_order": 1 },
        { "key": "region",      "data_type": "string",  "description": "Cloud region",       "display_order": 2 },
        { "key": "project_id",  "data_type": "string",  "description": "Parent project",     "display_order": 3 },
        { "key": "health",      "data_type": "string",  "description": "healthy | degraded | down", "display_order": 4,
          "options": { "values": ["healthy", "degraded", "down"] } },
        { "key": "last_deploy", "data_type": "datetime","description": "Last deployment",    "display_order": 5 },
        { "key": "version",     "data_type": "string",  "description": "Running version",    "display_order": 6 }
      ]
    },
    {
      "id": "demo:product",
      "class_id": "@class",
      "name": "SaaS Product",
      "namespace_id": "demo",
      "description": "A software product or SaaS offering",
      "icon": "package",
      "color": "#06b6d4",
      "props": [
        { "key": "tagline",   "data_type": "string",  "description": "One-line pitch",      "display_order": 0 },
        { "key": "status",    "data_type": "string",  "description": "beta | ga | deprecated", "display_order": 1,
          "options": { "values": ["beta", "ga", "deprecated", "planned"] } },
        { "key": "version",   "data_type": "string",  "description": "Current version",     "display_order": 2 },
        { "key": "users",     "data_type": "integer", "description": "Active user count",   "display_order": 3 },
        { "key": "mrr",       "data_type": "float",   "description": "Monthly recurring revenue (USD)", "display_order": 4 },
        { "key": "uptime",    "data_type": "float",   "description": "30-day uptime %",     "display_order": 5 },
        { "key": "docs_url",  "data_type": "string",  "description": "Documentation URL",   "display_order": 6 }
      ]
    }
  ],
  "objects": [
    {
      "id": "tenant:demo",
      "class_id": "es:tenant",
      "name": "Demo",
      "description": "Public demo tenant — pre-loaded with sample data. Visitors can explore without signing up.",
      "domain": "demo.arc3d.ai",
      "owner_id": "asi",
      "app_id": "arc3d",
      "plan": "enterprise",
      "status": "active",
      "is_demo": true,
      "limits": {
        "max_objects": 10000,
        "max_classes": 500,
        "max_users": 100,
        "max_storage_mb": 1024
      }
    },

    {
      "id": "demo:server.refresh",
      "class_id": "@action",
      "name": "Refresh Status",
      "description": "Fetch latest status from cloud provider API",
      "type": "api",
      "target_class_id": "demo:server",
      "method": "GET",
      "endpoint": "/service/server/{_link_id}",
      "response_mapping": { "power": "status", "cpu": "cpu_usage", "ram": "ram_usage" },
      "icon": "refresh-cw"
    },
    {
      "id": "demo:server.power_off",
      "class_id": "@action",
      "name": "Power Off",
      "description": "Send power-off command to server",
      "type": "api",
      "target_class_id": "demo:server",
      "method": "PUT",
      "endpoint": "/service/server/{_link_id}/power",
      "request_mapping": { "power": "off" },
      "response_mapping": { "power": "status" },
      "icon": "power"
    },
    {
      "id": "demo:server.reboot",
      "class_id": "@action",
      "name": "Reboot",
      "description": "Reboot the server",
      "type": "api",
      "target_class_id": "demo:server",
      "method": "PUT",
      "endpoint": "/service/server/{_link_id}/power",
      "request_mapping": { "power": "reboot" },
      "response_mapping": { "power": "status" },
      "icon": "rotate-ccw"
    },
    {
      "id": "demo:task.assign",
      "class_id": "@action",
      "name": "Assign",
      "description": "Assign task to a team member",
      "type": "function",
      "target_class_id": "demo:task",
      "icon": "user-check"
    },
    {
      "id": "demo:task.close",
      "class_id": "@action",
      "name": "Close",
      "description": "Mark task as done",
      "type": "function",
      "target_class_id": "demo:task",
      "icon": "check-circle"
    },
    {
      "id": "demo:environment.deploy",
      "class_id": "@action",
      "name": "Deploy",
      "description": "Trigger a deployment to this environment",
      "type": "api",
      "target_class_id": "demo:environment",
      "method": "POST",
      "endpoint": "/deploy/{id}",
      "icon": "upload-cloud"
    },
    {
      "id": "demo:environment.health_check",
      "class_id": "@action",
      "name": "Health Check",
      "description": "Ping the environment and update health status",
      "type": "api",
      "target_class_id": "demo:environment",
      "method": "GET",
      "endpoint": "/health/{url}",
      "icon": "activity"
    },

