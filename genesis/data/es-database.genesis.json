{
  "version": "1.0.0",
  "namespace": "es",
  "description": "ElementStore self-monitoring: CouchDB database objects with live stats sync via @action + @provider",
  "classes": [
    {
      "id": "es:database",
      "class_id": "@class",
      "name": "ES Database",
      "description": "CouchDB database with live stats synced via @action",
      "icon": "database",
      "props": [
        {
          "key": "name",
          "label": "Name",
          "data_type": "string",
          "display_order": 1,
          "flags": {
            "required": true
          },
          "class_id": "@prop_string"
        },
        {
          "key": "doc_count",
          "label": "Documents",
          "data_type": "integer",
          "display_order": 2,
          "flags": {
            "readonly": true
          },
          "class_id": "@prop_number"
        },
        {
          "key": "disk_size",
          "label": "Disk Size",
          "data_type": "integer",
          "display_order": 3,
          "flags": {
            "readonly": true
          },
          "class_id": "@prop_number"
        },
        {
          "key": "active_size",
          "label": "Active Size",
          "data_type": "integer",
          "display_order": 4,
          "flags": {
            "readonly": true
          },
          "class_id": "@prop_number"
        },
        {
          "key": "del_count",
          "label": "Deleted Docs",
          "data_type": "integer",
          "display_order": 5,
          "flags": {
            "readonly": true
          },
          "class_id": "@prop_number"
        },
        {
          "key": "compact",
          "label": "Compacting",
          "data_type": "boolean",
          "display_order": 6,
          "flags": {
            "readonly": true
          },
          "class_id": "@prop_boolean"
        },
        {
          "key": "synced_at",
          "label": "Last Synced",
          "data_type": "string",
          "display_order": 7,
          "flags": {
            "readonly": true
          },
          "class_id": "@prop_string"
        },
        {
          "key": "_links",
          "label": "Provider Links",
          "description": "Maps provider_id to external resource ID",
          "data_type": "object",
          "display_order": 90,
          "class_id": "@prop_object"
        },
        {
          "key": "refresh",
          "label": "Refresh Stats",
          "description": "Sync database stats from CouchDB",
          "data_type": "function",
          "object_class_id": [
            "@action"
          ],
          "icon": "refresh-cw",
          "display_order": 100,
          "class_id": "@prop_function"
        }
      ]
    }
  ],
  "seed": [
    {
      "storage": "./es-database.seed.json"
    }
  ]
}