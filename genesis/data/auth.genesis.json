{
  "version": "2.0.0",
  "namespace": "auth",
  "source_project": "auth-service",
  "description": "Auth-service data models — users, machines, sessions, applications, roles, modules, permissions. Classes mirror the auth-service internal schema (types.ts); secrets (passwords, api_key_hash, tokens) are excluded. Timestamps (created_at, updated_at) are system-managed base @class props.",
  "classes": [
    {
      "id": "auth:user",
      "class_id": "@class",
      "name": "User",
      "description": "A user account managed by auth-service.",
      "props": [
        {
          "id": "auth:user.email",
          "class_id": "@prop",
          "key": "email",
          "data_type": "string",
          "description": "Unique login email",
          "display_order": 0,
          "flags": { "required": true }
        },
        {
          "id": "auth:user.name",
          "class_id": "@prop",
          "key": "name",
          "data_type": "string",
          "description": "Display name",
          "display_order": 1
        },
        {
          "id": "auth:user.phone",
          "class_id": "@prop",
          "key": "phone",
          "data_type": "string",
          "description": "Phone number for OTP / contact",
          "display_order": 2
        },
        {
          "id": "auth:user.phone_verified",
          "class_id": "@prop",
          "key": "phone_verified",
          "data_type": "boolean",
          "description": "Whether the phone number has been verified",
          "display_order": 3
        },
        {
          "id": "auth:user.email_verified",
          "class_id": "@prop",
          "key": "email_verified",
          "data_type": "boolean",
          "description": "Whether the user has verified their email address",
          "display_order": 4
        },
        {
          "id": "auth:user.is_active",
          "class_id": "@prop",
          "key": "is_active",
          "data_type": "boolean",
          "description": "Inactive users cannot log in",
          "display_order": 5
        },
        {
          "id": "auth:user.is_system",
          "class_id": "@prop",
          "key": "is_system",
          "data_type": "boolean",
          "description": "System users cannot be deleted or modified by regular admins",
          "display_order": 6
        },
        {
          "id": "auth:user.totp_enabled",
          "class_id": "@prop",
          "key": "totp_enabled",
          "data_type": "boolean",
          "description": "Whether TOTP two-factor authentication is enabled",
          "display_order": 7
        },
        {
          "id": "auth:user.failed_login_attempts",
          "class_id": "@prop",
          "key": "failed_login_attempts",
          "data_type": "number",
          "description": "Count of consecutive failed login attempts",
          "display_order": 8,
          "flags": { "readonly": true }
        },
        {
          "id": "auth:user.locked_until",
          "class_id": "@prop",
          "key": "locked_until",
          "data_type": "datetime",
          "description": "Account locked until this timestamp (after too many failed attempts)",
          "display_order": 9,
          "flags": { "readonly": true }
        }
      ]
    },
    {
      "id": "auth:application",
      "class_id": "@class",
      "name": "Application",
      "description": "An application registered with auth-service. Each app has its own roles, modules, and permissions.",
      "props": [
        {
          "id": "auth:application.name",
          "class_id": "@prop",
          "key": "name",
          "data_type": "string",
          "description": "Unique application identifier/slug",
          "display_order": 0,
          "flags": { "required": true }
        },
        {
          "id": "auth:application.display_name",
          "class_id": "@prop",
          "key": "display_name",
          "data_type": "string",
          "description": "Human-readable application name",
          "display_order": 1
        },
        {
          "id": "auth:application.description",
          "class_id": "@prop",
          "key": "description",
          "data_type": "string",
          "description": "What this application does",
          "display_order": 2
        },
        {
          "id": "auth:application.is_default",
          "class_id": "@prop",
          "key": "is_default",
          "data_type": "boolean",
          "description": "Default application used when none specified",
          "display_order": 3
        },
        {
          "id": "auth:application.is_system",
          "class_id": "@prop",
          "key": "is_system",
          "data_type": "boolean",
          "description": "System applications cannot be deleted",
          "display_order": 4
        }
      ]
    },
    {
      "id": "auth:role",
      "class_id": "@class",
      "name": "Role",
      "description": "A named role scoped to an application. Roles group permissions and are assigned to users via user_app_access.",
      "props": [
        {
          "id": "auth:role.app_id",
          "class_id": "@prop",
          "key": "app_id",
          "data_type": "string",
          "description": "Application this role belongs to (auth:application.id)",
          "display_order": 0,
          "flags": { "required": true }
        },
        {
          "id": "auth:role.name",
          "class_id": "@prop",
          "key": "name",
          "data_type": "string",
          "description": "Unique role name within the app (e.g. admin, editor, viewer)",
          "display_order": 1,
          "flags": { "required": true }
        },
        {
          "id": "auth:role.display_name",
          "class_id": "@prop",
          "key": "display_name",
          "data_type": "string",
          "description": "Human-readable role name",
          "display_order": 2
        },
        {
          "id": "auth:role.description",
          "class_id": "@prop",
          "key": "description",
          "data_type": "string",
          "description": "What this role allows",
          "display_order": 3
        },
        {
          "id": "auth:role.is_system",
          "class_id": "@prop",
          "key": "is_system",
          "data_type": "boolean",
          "description": "System roles cannot be deleted",
          "display_order": 4,
          "flags": { "readonly": true }
        }
      ]
    },
    {
      "id": "auth:module",
      "class_id": "@class",
      "name": "Module",
      "description": "A functional module within an application that can be permission-gated (e.g. billing, reports, admin).",
      "props": [
        {
          "id": "auth:module.app_id",
          "class_id": "@prop",
          "key": "app_id",
          "data_type": "string",
          "description": "Application this module belongs to (auth:application.id)",
          "display_order": 0,
          "flags": { "required": true }
        },
        {
          "id": "auth:module.name",
          "class_id": "@prop",
          "key": "name",
          "data_type": "string",
          "description": "Unique module key within the app (e.g. billing, reports)",
          "display_order": 1,
          "flags": { "required": true }
        },
        {
          "id": "auth:module.display_name",
          "class_id": "@prop",
          "key": "display_name",
          "data_type": "string",
          "description": "Human-readable module name",
          "display_order": 2
        },
        {
          "id": "auth:module.description",
          "class_id": "@prop",
          "key": "description",
          "data_type": "string",
          "description": "What this module controls access to",
          "display_order": 3
        }
      ]
    },
    {
      "id": "auth:permission",
      "class_id": "@class",
      "name": "Permission",
      "description": "A specific permission within a module (e.g. read, write, delete). Assigned to roles via role_permission.",
      "props": [
        {
          "id": "auth:permission.module_id",
          "class_id": "@prop",
          "key": "module_id",
          "data_type": "string",
          "description": "Module this permission belongs to (auth:module.id)",
          "display_order": 0,
          "flags": { "required": true }
        },
        {
          "id": "auth:permission.name",
          "class_id": "@prop",
          "key": "name",
          "data_type": "string",
          "description": "Permission name (e.g. read, write, delete, admin)",
          "display_order": 1,
          "flags": { "required": true }
        },
        {
          "id": "auth:permission.display_name",
          "class_id": "@prop",
          "key": "display_name",
          "data_type": "string",
          "description": "Human-readable permission name",
          "display_order": 2
        },
        {
          "id": "auth:permission.description",
          "class_id": "@prop",
          "key": "description",
          "data_type": "string",
          "description": "What this permission grants",
          "display_order": 3
        }
      ]
    },
    {
      "id": "auth:role_permission",
      "class_id": "@class",
      "name": "Role Permission",
      "description": "Junction table linking a role to a permission.",
      "props": [
        {
          "id": "auth:role_permission.role_id",
          "class_id": "@prop",
          "key": "role_id",
          "data_type": "string",
          "description": "Role this permission is assigned to (auth:role.id)",
          "display_order": 0,
          "flags": { "required": true }
        },
        {
          "id": "auth:role_permission.permission_id",
          "class_id": "@prop",
          "key": "permission_id",
          "data_type": "string",
          "description": "Permission being granted (auth:permission.id)",
          "display_order": 1,
          "flags": { "required": true }
        }
      ]
    },
    {
      "id": "auth:user_app_access",
      "class_id": "@class",
      "name": "User App Access",
      "description": "Maps a user to an application with a specific role. Controls which apps a user can access and their role in each.",
      "props": [
        {
          "id": "auth:user_app_access.user_id",
          "class_id": "@prop",
          "key": "user_id",
          "data_type": "string",
          "description": "User being granted access (auth:user.id)",
          "display_order": 0,
          "flags": { "required": true }
        },
        {
          "id": "auth:user_app_access.app_id",
          "class_id": "@prop",
          "key": "app_id",
          "data_type": "string",
          "description": "Application being accessed (auth:application.id)",
          "display_order": 1,
          "flags": { "required": true }
        },
        {
          "id": "auth:user_app_access.role_id",
          "class_id": "@prop",
          "key": "role_id",
          "data_type": "string",
          "description": "Role assigned to user in this app (auth:role.id)",
          "display_order": 2,
          "flags": { "required": true }
        },
        {
          "id": "auth:user_app_access.is_active",
          "class_id": "@prop",
          "key": "is_active",
          "data_type": "boolean",
          "description": "Whether this access grant is active",
          "display_order": 3
        }
      ]
    },
    {
      "id": "auth:machine",
      "class_id": "@class",
      "name": "Machine",
      "description": "A machine/service account that authenticates via API key. Machines have a role within an app and can optionally connect to an elementStore instance.",
      "props": [
        {
          "id": "auth:machine.name",
          "class_id": "@prop",
          "key": "name",
          "data_type": "string",
          "description": "Unique machine identifier/slug",
          "display_order": 0,
          "flags": { "required": true }
        },
        {
          "id": "auth:machine.display_name",
          "class_id": "@prop",
          "key": "display_name",
          "data_type": "string",
          "description": "Human-readable machine name",
          "display_order": 1
        },
        {
          "id": "auth:machine.app_id",
          "class_id": "@prop",
          "key": "app_id",
          "data_type": "string",
          "description": "Application this machine belongs to (auth:application.id)",
          "display_order": 2,
          "flags": { "required": true }
        },
        {
          "id": "auth:machine.role_id",
          "class_id": "@prop",
          "key": "role_id",
          "data_type": "string",
          "description": "Role assigned to this machine (auth:role.id)",
          "display_order": 3,
          "flags": { "required": true }
        },
        {
          "id": "auth:machine.description",
          "class_id": "@prop",
          "key": "description",
          "data_type": "string",
          "description": "What this machine is used for",
          "display_order": 4
        },
        {
          "id": "auth:machine.es_url",
          "class_id": "@prop",
          "key": "es_url",
          "data_type": "string",
          "description": "ElementStore URL this machine connects to",
          "display_order": 5
        },
        {
          "id": "auth:machine.is_active",
          "class_id": "@prop",
          "key": "is_active",
          "data_type": "boolean",
          "description": "Inactive machines cannot authenticate",
          "display_order": 6
        },
        {
          "id": "auth:machine.last_used_at",
          "class_id": "@prop",
          "key": "last_used_at",
          "data_type": "datetime",
          "description": "Last time this machine authenticated",
          "display_order": 7,
          "flags": { "readonly": true }
        }
      ]
    },
    {
      "id": "auth:session",
      "class_id": "@class",
      "name": "Session",
      "description": "An active authentication session. Tracks refresh tokens and access token JTIs for a user or machine within an app.",
      "props": [
        {
          "id": "auth:session.user_id",
          "class_id": "@prop",
          "key": "user_id",
          "data_type": "string",
          "description": "User this session belongs to (auth:user.id). Null for machine sessions.",
          "display_order": 0
        },
        {
          "id": "auth:session.machine_id",
          "class_id": "@prop",
          "key": "machine_id",
          "data_type": "string",
          "description": "Machine this session belongs to (auth:machine.id). Null for user sessions.",
          "display_order": 1
        },
        {
          "id": "auth:session.app_id",
          "class_id": "@prop",
          "key": "app_id",
          "data_type": "string",
          "description": "Application this session is for (auth:application.id)",
          "display_order": 2,
          "flags": { "required": true }
        },
        {
          "id": "auth:session.refresh_token",
          "class_id": "@prop",
          "key": "refresh_token",
          "data_type": "string",
          "description": "Hashed refresh token for this session",
          "display_order": 3,
          "flags": { "server_only": true }
        },
        {
          "id": "auth:session.access_token_jti",
          "class_id": "@prop",
          "key": "access_token_jti",
          "data_type": "string",
          "description": "JTI of the current access token (for revocation)",
          "display_order": 4,
          "flags": { "server_only": true }
        },
        {
          "id": "auth:session.ip_address",
          "class_id": "@prop",
          "key": "ip_address",
          "data_type": "string",
          "description": "IP address that created this session",
          "display_order": 5,
          "flags": { "readonly": true }
        },
        {
          "id": "auth:session.user_agent",
          "class_id": "@prop",
          "key": "user_agent",
          "data_type": "string",
          "description": "User-Agent string from the session creation request",
          "display_order": 6,
          "flags": { "readonly": true }
        },
        {
          "id": "auth:session.expires_at",
          "class_id": "@prop",
          "key": "expires_at",
          "data_type": "datetime",
          "description": "When this session expires",
          "display_order": 7,
          "flags": { "readonly": true }
        }
      ]
    },
    {
      "id": "auth:scope",
      "class_id": "@class",
      "name": "Scope",
      "description": "A permission scope that can require MFA. Scopes control access to sensitive operations and can inject payload variables into tokens.",
      "props": [
        {
          "id": "auth:scope.app_id",
          "class_id": "@prop",
          "key": "app_id",
          "data_type": "string",
          "description": "Application this scope belongs to (auth:application.id)",
          "display_order": 0,
          "flags": { "required": true }
        },
        {
          "id": "auth:scope.name",
          "class_id": "@prop",
          "key": "name",
          "data_type": "string",
          "description": "Unique scope name within the app",
          "display_order": 1,
          "flags": { "required": true }
        },
        {
          "id": "auth:scope.display_name",
          "class_id": "@prop",
          "key": "display_name",
          "data_type": "string",
          "description": "Human-readable scope name",
          "display_order": 2
        },
        {
          "id": "auth:scope.description",
          "class_id": "@prop",
          "key": "description",
          "data_type": "string",
          "description": "What this scope controls",
          "display_order": 3
        },
        {
          "id": "auth:scope.require_mfa",
          "class_id": "@prop",
          "key": "require_mfa",
          "data_type": "boolean",
          "description": "Whether this scope requires multi-factor authentication",
          "display_order": 4
        },
        {
          "id": "auth:scope.mfa_types",
          "class_id": "@prop",
          "key": "mfa_types",
          "data_type": "string",
          "description": "Allowed MFA types as JSON array: [\"sms\",\"email\",\"totp\"]",
          "display_order": 5
        },
        {
          "id": "auth:scope.is_system",
          "class_id": "@prop",
          "key": "is_system",
          "data_type": "boolean",
          "description": "System scopes cannot be deleted",
          "display_order": 6,
          "flags": { "readonly": true }
        }
      ]
    },
    {
      "id": "auth:setting",
      "class_id": "@class",
      "name": "Auth Setting",
      "description": "Key-value configuration settings for auth-service. Can be global or scoped to an application.",
      "props": [
        {
          "id": "auth:setting.app_id",
          "class_id": "@prop",
          "key": "app_id",
          "data_type": "string",
          "description": "Application this setting applies to (null = global)",
          "display_order": 0
        },
        {
          "id": "auth:setting.key",
          "class_id": "@prop",
          "key": "key",
          "data_type": "string",
          "description": "Setting key",
          "display_order": 1,
          "flags": { "required": true }
        },
        {
          "id": "auth:setting.value",
          "class_id": "@prop",
          "key": "value",
          "data_type": "string",
          "description": "Setting value",
          "display_order": 2,
          "flags": { "required": true }
        },
        {
          "id": "auth:setting.is_public",
          "class_id": "@prop",
          "key": "is_public",
          "data_type": "boolean",
          "description": "Whether this setting is visible to unauthenticated clients",
          "display_order": 3
        },
        {
          "id": "auth:setting.description",
          "class_id": "@prop",
          "key": "description",
          "data_type": "string",
          "description": "What this setting controls",
          "display_order": 4
        }
      ]
    },
    {
      "id": "auth:tenant",
      "class_id": "@class",
      "name": "Tenant",
      "description": "A tenant/organization for multi-tenant isolation. Users belong to tenants with specific roles.",
      "props": [
        {
          "id": "auth:tenant.name",
          "class_id": "@prop",
          "key": "name",
          "data_type": "string",
          "description": "Unique tenant slug",
          "display_order": 0,
          "flags": { "required": true }
        },
        {
          "id": "auth:tenant.display_name",
          "class_id": "@prop",
          "key": "display_name",
          "data_type": "string",
          "description": "Human-readable tenant name",
          "display_order": 1
        },
        {
          "id": "auth:tenant.description",
          "class_id": "@prop",
          "key": "description",
          "data_type": "string",
          "description": "Tenant description",
          "display_order": 2
        },
        {
          "id": "auth:tenant.is_active",
          "class_id": "@prop",
          "key": "is_active",
          "data_type": "boolean",
          "description": "Whether this tenant is active",
          "display_order": 3
        },
        {
          "id": "auth:tenant.is_default",
          "class_id": "@prop",
          "key": "is_default",
          "data_type": "boolean",
          "description": "Default tenant for users without explicit tenant assignment",
          "display_order": 4
        }
      ]
    },
    {
      "id": "auth:tenant_user",
      "class_id": "@class",
      "name": "Tenant User",
      "description": "Maps a user to a tenant with a role (owner, admin, member).",
      "props": [
        {
          "id": "auth:tenant_user.tenant_id",
          "class_id": "@prop",
          "key": "tenant_id",
          "data_type": "string",
          "description": "Tenant (auth:tenant.id)",
          "display_order": 0,
          "flags": { "required": true }
        },
        {
          "id": "auth:tenant_user.user_id",
          "class_id": "@prop",
          "key": "user_id",
          "data_type": "string",
          "description": "User (auth:user.id)",
          "display_order": 1,
          "flags": { "required": true }
        },
        {
          "id": "auth:tenant_user.role",
          "class_id": "@prop",
          "key": "role",
          "data_type": "string",
          "description": "Role within tenant: owner | admin | member",
          "display_order": 2,
          "flags": { "required": true }
        },
        {
          "id": "auth:tenant_user.is_active",
          "class_id": "@prop",
          "key": "is_active",
          "data_type": "boolean",
          "description": "Whether this membership is active",
          "display_order": 3
        }
      ]
    }
  ]
}
