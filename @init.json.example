{
  "@storage": {
    "bootstrap": {
      "id": "bootstrap",
      "class_id": "@storage",
      "type": "composite",
      "_note": "username/password: set COUCHDB_USER and COUCHDB_PASSWORD env vars (see ClassModel::boot). Do not hardcode credentials here.",
      "read": [
        {"type": "couchdb", "server": "http://elementstore_couchdb:5984"}
      ],
      "write": [
        {"type": "couchdb", "server": "http://elementstore_couchdb:5984"},
        {"type": "json", "dir": ".es"}
      ],
      "read_strategy": "fallback",
      "write_strategy": "best_effort"
    }
  },
  "genesis": {
    "mode": "local",
    "url": null,
    "auto_load": true
  }
}
