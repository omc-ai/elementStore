{
  "id": "bootstrap",
  "class_id": "@storage",
  "name": "Bootstrap Storage",
  "type": "couchdb",
  "server": "http://elementstore_couchdb:5984",
  "classes": {
    "@class": ["get", "set", "query", "delete"]
  },
  "providers": [
    {
      "id": "genesis_files",
      "class_id": "@storage",
      "name": "Genesis JSON Files",
      "type": "json",
      "dir": ".es",
      "classes": {
        "@class": ["get", "set"],
        "@editor": ["get"],
        "@function": ["get"],
        "@action": ["get"],
        "@app": ["get"]
      }
    },
    {
      "id": "ws_broadcast",
      "class_id": "@storage",
      "name": "WebSocket Broadcast",
      "type": "ws",
      "classes": {
        "@class": ["set", "delete"]
      }
    }
  ],
  "method": "sync"
}
