{
  "id": "bootstrap",
  "class_id": "@storage",
  "name": "Bootstrap Storage",
  "type": "couchdb",
  "server": "http://elementstore_couchdb:5984",
  "classes": {
    "@class": ["get", "set", "query", "delete"]
  },
  "providers": [
    {
      "id": "genesis_files",
      "class_id": "@storage",
      "name": "Genesis JSON Files",
      "type": "json",
      "dir": ".es",
      "classes": {
        "@class": ["get", "query"]
      }
    }
  ],
  "method": "sync"
}
