[
  {
    "id": "act:cwm-list-servers",
    "class_id": "@action",
    "name": "List Servers",
    "description": "List all CloudWM servers in the account. Returns server name, datacenter, status, CPU, RAM, and IP addresses.",
    "type": "api",
    "group_name": "cloudwm",
    "method": "GET",
    "endpoint": "/service/servers",
    "returns": "list",
    "params": [
      {"key": "datacenter", "label": "Datacenter", "description": "Filter by datacenter code (e.g. EU, IL, US-NY2)", "data_type": "string", "class_id": "@prop"}
    ],
    "response_mapping": {"id": "id", "name": "name", "datacenter": "datacenter", "status": "power", "cpus": "cpuType", "ram": "ram", "networks": "networks"},
    "requires_selection": false,
    "bulk": false
  },
  {
    "id": "act:cwm-create-server",
    "class_id": "@action",
    "name": "Create Server",
    "description": "Create a new CloudWM cloud server. Returns a job command ID — poll status to get the server ID once provisioned.",
    "type": "api",
    "group_name": "cloudwm",
    "method": "POST",
    "endpoint": "/service/server",
    "returns": "object",
    "params": [
      {"key": "name", "label": "Server Name", "description": "Hostname/display name for the server", "data_type": "string", "class_id": "@prop"},
      {"key": "datacenter", "label": "Datacenter", "description": "Datacenter code (e.g. EU, IL, US-NY2)", "data_type": "string", "class_id": "@prop"},
      {"key": "image", "label": "Image", "description": "OS image ID (use /service/servers/images to list available images)", "data_type": "string", "class_id": "@prop"},
      {"key": "cpu", "label": "CPU Type", "description": "CPU type code (e.g. B for burstable, D for dedicated)", "data_type": "string", "class_id": "@prop"},
      {"key": "ram", "label": "RAM (MB)", "description": "RAM in megabytes (e.g. 1024, 2048, 4096)", "data_type": "integer", "class_id": "@prop"},
      {"key": "disk", "label": "Disk Size (GB)", "description": "Primary disk size in GB", "data_type": "integer", "class_id": "@prop"},
      {"key": "password", "label": "Root Password", "description": "Root/admin password for the new server", "data_type": "string", "class_id": "@prop"},
      {"key": "network", "label": "Network", "description": "Network configuration name (e.g. wan)", "data_type": "string", "class_id": "@prop"},
      {"key": "daily_backup", "label": "Daily Backup", "description": "Enable daily automated backup", "data_type": "boolean", "class_id": "@prop"}
    ],
    "request_mapping": {"name": "name", "datacenter": "datacenter", "image": "image", "cpu": "cpu", "ram": "ram", "disk": "disk", "password": "password", "network": "network", "dailybackup": "daily_backup"},
    "response_mapping": {"commandIds": "job_ids", "servers": "servers"},
    "requires_selection": false,
    "bulk": false
  },
  {
    "id": "act:cwm-power-on",
    "class_id": "@action",
    "name": "Power On Server",
    "description": "Power on a stopped CloudWM server by server name. Returns a command ID.",
    "type": "api",
    "group_name": "cloudwm",
    "method": "POST",
    "endpoint": "/service/server/powerOn",
    "returns": "object",
    "params": [
      {"key": "name", "label": "Server Name", "description": "Name of the server to power on", "data_type": "string", "class_id": "@prop"}
    ],
    "request_mapping": {"name": "name"},
    "response_mapping": {"commandId": "job_id"},
    "requires_selection": true,
    "bulk": false
  },
  {
    "id": "act:cwm-power-off",
    "class_id": "@action",
    "name": "Power Off Server",
    "description": "Power off a running CloudWM server by server name. Hard powers down the VM. Returns a command ID.",
    "type": "api",
    "group_name": "cloudwm",
    "method": "POST",
    "endpoint": "/service/server/powerOff",
    "returns": "object",
    "params": [
      {"key": "name", "label": "Server Name", "description": "Name of the server to power off", "data_type": "string", "class_id": "@prop"}
    ],
    "request_mapping": {"name": "name"},
    "response_mapping": {"commandId": "job_id"},
    "requires_selection": true,
    "bulk": false
  },
  {
    "id": "provider:cloudwm",
    "class_id": "@cloudwm",
    "name": "CloudWM",
    "description": "CloudWM (Kamatera) API provider instance. Manages cloud servers — list, create, power on/off. Configure auth with CWM_CLIENTID and CWM_SECRET environment variables.",
    "base_url": "https://cloudwm.com/api",
    "write_mode": "crud",
    "auth": {
      "type": "apikey",
      "headers": {
        "AuthClientId": "${CWM_CLIENTID}",
        "AuthSecret": "${CWM_SECRET}"
      },
      "_note": "Set CWM_CLIENTID and CWM_SECRET environment variables with your CloudWM API credentials."
    },
    "id_field": "name",
    "actions": ["act:cwm-list-servers", "act:cwm-create-server", "act:cwm-power-on", "act:cwm-power-off"],
    "mapping": {"id": "name", "name": "name"}
  }
]
