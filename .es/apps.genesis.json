{
  "id": "es-apps",
  "class_id": "@seed",
  "name": "ES Application & Feature Tracking",
  "description": "Self-aware registry of applications that use elementStore, canonical ES features, and per-app feature implementation progress",
  "version": "1.0.0",
  "classes": [
    {
      "id": "@app",
      "class_id": "@class",
      "name": "ES Application",
      "description": "An application that uses elementStore — as server, client, or declaration provider",
      "props": [
        {
          "key": "name",
          "label": "Name",
          "description": "Application name",
          "data_type": "string",
          "display_order": 1,
          "flags": {
            "required": true
          },
          "class_id": "@prop_string"
        },
        {
          "key": "description",
          "label": "Description",
          "description": "What this app does",
          "data_type": "string",
          "editor": {
            "id": "textarea"
          },
          "display_order": 2,
          "class_id": "@prop_string"
        },
        {
          "key": "application_id",
          "label": "Application",
          "description": "Links to @application in platform_root registry",
          "data_type": "string",
          "display_order": 3,
          "class_id": "@prop_string"
        },
        {
          "key": "role",
          "label": "Role",
          "description": "How this app relates to elementStore",
          "data_type": "string",
          "options": {
            "type": "string_options",
            "values": [
              "server",
              "client",
              "provider",
              "declaration"
            ]
          },
          "editor": {
            "id": "select"
          },
          "display_order": 4,
          "flags": {
            "required": true
          },
          "class_id": "@prop_string"
        },
        {
          "key": "server_url",
          "label": "Server URL",
          "description": "ES API URL (serves or connects to)",
          "data_type": "string",
          "editor": {
            "id": "url"
          },
          "display_order": 5,
          "class_id": "@prop_string"
        },
        {
          "key": "repositories",
          "label": "Repositories",
          "description": "Repository IDs that interact with ES",
          "data_type": "string",
          "is_array": "indexed",
          "display_order": 6,
          "class_id": "@prop_string"
        },
        {
          "key": "genesis_files",
          "label": "Genesis Files",
          "description": "Genesis/seed file paths",
          "data_type": "string",
          "is_array": "indexed",
          "display_order": 7,
          "class_id": "@prop_string"
        },
        {
          "key": "class_count",
          "label": "Class Count",
          "description": "Total ES classes this app defines",
          "data_type": "integer",
          "display_order": 8,
          "class_id": "@prop_number"
        },
        {
          "key": "crud_providers",
          "label": "CRUD Providers",
          "description": "CRUD provider IDs for API mapping",
          "data_type": "string",
          "is_array": "indexed",
          "display_order": 9,
          "class_id": "@prop_string"
        },
        {
          "key": "client_language",
          "label": "Client Language",
          "description": "Primary language of ES client code",
          "data_type": "string",
          "options": {
            "type": "string_options",
            "values": [
              "typescript",
              "php",
              "bash",
              "none"
            ]
          },
          "editor": {
            "id": "select"
          },
          "default_value": "none",
          "display_order": 10,
          "class_id": "@prop_string"
        },
        {
          "key": "status",
          "label": "Status",
          "description": "Current status of this app's ES integration",
          "data_type": "string",
          "options": {
            "type": "string_options",
            "values": [
              "active",
              "planned",
              "deprecated"
            ]
          },
          "editor": {
            "id": "select"
          },
          "default_value": "active",
          "display_order": 11,
          "class_id": "@prop_string"
        }
      ],
      "icon": "app-window",
      "color": "#6366f1",
      "contexts": {
        "grid": {
          "fields": [
            "name",
            "application_id",
            "role",
            "status",
            "server_url"
          ],
          "sort_by": "name",
          "page_size": 25,
          "title_field": "name",
          "badge_field": "status",
          "template": "list-item",
          "columns": [
            {
              "field": "name",
              "label": "App",
              "type": "text",
              "width": 200
            },
            {
              "field": "application_id",
              "label": "ID",
              "type": "text",
              "width": 140
            },
            {
              "field": "role",
              "label": "Role",
              "type": "badge",
              "width": 120
            },
            {
              "field": "status",
              "label": "Status",
              "type": "badge",
              "width": 100
            },
            {
              "field": "server_url",
              "label": "URL",
              "type": "link",
              "width": 200
            }
          ]
        },
        "card": {
          "template": "card-default",
          "title_field": "name",
          "subtitle_field": "description",
          "badge_field": "role",
          "fields": [
            "name",
            "description",
            "application_id",
            "role",
            "status"
          ]
        },
        "form": {
          "template": "form-default",
          "title_field": "name",
          "sections": [
            {
              "title": "Identity",
              "columns": 2,
              "fields": [
                "name",
                "application_id",
                "role",
                "status"
              ]
            },
            {
              "title": "Connection",
              "columns": 1,
              "fields": [
                "server_url",
                "description"
              ]
            },
            {
              "title": "Details",
              "collapsed": true,
              "fields": [
                "genesis_files",
                "repositories",
                "class_count",
                "client_language"
              ]
            }
          ]
        },
        "compact": {
          "template": "list-item",
          "title_field": "name",
          "badge_field": "role",
          "fields": [
            "name",
            "role",
            "status"
          ]
        }
      }
    },
    {
      "id": "@feature",
      "class_id": "@class",
      "name": "ES Feature",
      "description": "A canonical elementStore capability that can be implemented by clients and servers",
      "props": [
        {
          "key": "name",
          "label": "Name",
          "description": "Feature name",
          "data_type": "string",
          "display_order": 1,
          "flags": {
            "required": true
          },
          "class_id": "@prop_string"
        },
        {
          "key": "description",
          "label": "Description",
          "description": "What this feature does",
          "data_type": "string",
          "editor": {
            "id": "textarea"
          },
          "display_order": 2,
          "class_id": "@prop_string"
        },
        {
          "key": "category",
          "label": "Category",
          "description": "Broad classification of the feature area",
          "data_type": "string",
          "options": {
            "type": "string_options",
            "values": [
              "core",
              "data",
              "schema",
              "integration",
              "system"
            ]
          },
          "editor": {
            "id": "select"
          },
          "display_order": 3,
          "flags": {
            "required": true
          },
          "class_id": "@prop_string"
        },
        {
          "key": "group",
          "label": "Group",
          "description": "Feature sub-group for display organization within a category",
          "data_type": "string",
          "options": {
            "type": "string_options",
            "values": [
              "object",
              "query",
              "relation",
              "class",
              "schema",
              "data",
              "actions",
              "events",
              "provider",
              "storage",
              "auth",
              "health",
              "modules",
              "types"
            ]
          },
          "editor": {
            "id": "select"
          },
          "display_order": 4,
          "class_id": "@prop_string"
        },
        {
          "key": "scope",
          "label": "Scope",
          "description": "Whether this feature applies to server, client, or both",
          "data_type": "string",
          "options": {
            "type": "string_options",
            "values": [
              "server",
              "client",
              "both"
            ]
          },
          "editor": {
            "id": "select"
          },
          "display_order": 5,
          "flags": {
            "required": true
          },
          "class_id": "@prop_string"
        },
        {
          "key": "api_endpoints",
          "label": "API Endpoints",
          "description": "Related API routes",
          "data_type": "string",
          "is_array": "indexed",
          "display_order": 6,
          "class_id": "@prop_string"
        },
        {
          "key": "depends_on",
          "label": "Depends On",
          "description": "Other features this depends on",
          "data_type": "relation",
          "object_class_id": [
            "@feature"
          ],
          "is_array": "indexed",
          "display_order": 7,
          "class_id": "@prop_relation"
        },
        {
          "key": "notes",
          "label": "Notes",
          "description": "Detailed logic description: classes, interfaces, actions, and how they interact",
          "data_type": "string",
          "editor": {
            "id": "textarea"
          },
          "display_order": 8,
          "class_id": "@prop_string"
        }
      ],
      "icon": "sparkles",
      "color": "#8b5cf6",
      "contexts": {
        "grid": {
          "fields": [
            "name",
            "category",
            "scope",
            "group"
          ],
          "sort_by": "name",
          "page_size": 50,
          "title_field": "name",
          "badge_field": "category",
          "template": "list-item",
          "columns": [
            {
              "field": "name",
              "label": "Feature",
              "type": "text",
              "width": 250
            },
            {
              "field": "category",
              "label": "Category",
              "type": "badge",
              "width": 120
            },
            {
              "field": "scope",
              "label": "Scope",
              "type": "badge",
              "width": 100
            },
            {
              "field": "group",
              "label": "Group",
              "type": "text",
              "width": 130
            },
            {
              "field": "description",
              "label": "Description",
              "type": "text",
              "width": 300
            }
          ]
        },
        "card": {
          "template": "card-default",
          "title_field": "name",
          "subtitle_field": "description",
          "badge_field": "category",
          "fields": [
            "name",
            "description",
            "category",
            "scope",
            "group"
          ]
        },
        "form": {
          "template": "form-default",
          "title_field": "name",
          "sections": [
            {
              "title": "Feature",
              "columns": 2,
              "fields": [
                "name",
                "category",
                "scope",
                "group"
              ]
            },
            {
              "title": "Details",
              "columns": 1,
              "fields": [
                "description",
                "depends_on",
                "api_endpoints",
                "notes"
              ]
            }
          ]
        },
        "compact": {
          "template": "list-item",
          "title_field": "name",
          "badge_field": "category",
          "fields": [
            "name",
            "category",
            "scope"
          ]
        }
      }
    },
    {
      "id": "@app_feature",
      "class_id": "@class",
      "name": "App Feature Progress",
      "description": "Tracks which ES features each application implements and their implementation progress",
      "props": [
        {
          "key": "application_id",
          "label": "Application",
          "description": "The @app this feature record belongs to",
          "data_type": "relation",
          "object_class_id": [
            "@app"
          ],
          "display_order": 1,
          "flags": {
            "required": true
          },
          "class_id": "@prop_relation"
        },
        {
          "key": "feature_id",
          "label": "Feature",
          "description": "The feature",
          "data_type": "relation",
          "object_class_id": [
            "@feature"
          ],
          "display_order": 2,
          "flags": {
            "required": true
          },
          "class_id": "@prop_relation"
        },
        {
          "key": "progress",
          "label": "Progress",
          "description": "Implementation progress",
          "data_type": "string",
          "options": {
            "type": "string_options",
            "values": [
              "not_started",
              "planned",
              "in_progress",
              "partial",
              "implemented",
              "tested"
            ]
          },
          "editor": {
            "id": "select"
          },
          "default_value": "not_started",
          "display_order": 3,
          "class_id": "@prop_string"
        },
        {
          "key": "server_endpoints",
          "label": "Server Endpoints",
          "description": "HTTP endpoints this app exposes as a server for this feature (empty if client-only)",
          "data_type": "string",
          "is_array": "indexed",
          "display_order": 4,
          "class_id": "@prop_string"
        },
        {
          "key": "notes",
          "label": "Notes",
          "description": "Implementation notes, limitations, known gaps",
          "data_type": "string",
          "editor": {
            "id": "textarea"
          },
          "display_order": 5,
          "class_id": "@prop_string"
        },
        {
          "key": "implemented_in",
          "label": "Implemented In",
          "description": "File paths (file:line) where this feature is implemented",
          "data_type": "string",
          "is_array": "indexed",
          "display_order": 6,
          "class_id": "@prop_string"
        }
      ],
      "icon": "check-circle",
      "color": "#10b981",
      "contexts": {
        "grid": {
          "fields": [
            "feature_id",
            "application_id",
            "progress",
            "implemented_in"
          ],
          "sort_by": "feature_id",
          "page_size": 50,
          "title_field": "feature_id",
          "badge_field": "progress",
          "template": "list-item",
          "columns": [
            {
              "field": "feature_id",
              "label": "Feature",
              "type": "relation",
              "width": 220
            },
            {
              "field": "application_id",
              "label": "App",
              "type": "relation",
              "width": 150
            },
            {
              "field": "progress",
              "label": "Progress",
              "type": "badge",
              "width": 130
            },
            {
              "field": "notes",
              "label": "Notes",
              "type": "text",
              "width": 250
            }
          ]
        },
        "card": {
          "template": "card-default",
          "title_field": "feature_id",
          "badge_field": "progress",
          "fields": [
            "feature_id",
            "application_id",
            "progress",
            "notes",
            "implemented_in"
          ]
        },
        "form": {
          "template": "form-default",
          "title_field": "feature_id",
          "sections": [
            {
              "title": "Feature",
              "columns": 2,
              "fields": [
                "feature_id",
                "application_id",
                "progress"
              ]
            },
            {
              "title": "Implementation",
              "columns": 1,
              "fields": [
                "implemented_in",
                "server_endpoints",
                "notes"
              ]
            }
          ]
        },
        "compact": {
          "template": "list-item",
          "title_field": "feature_id",
          "badge_field": "progress",
          "fields": [
            "feature_id",
            "application_id",
            "progress"
          ]
        }
      }
    }
  ],
  "seed": [
    {
      "storage": "./@app.json"
    },
    {
      "storage": "./@feature.json"
    },
    {
      "storage": "./@app_feature.json"
    }
  ]
}
