{
    "version": "1.0.0",
    "namespace": "signing",
    "description": "Action signing policy — every mutation is signed by user+agent and appended to the audit trail.",
    "classes": [],
    "objects": [
        {
            "id": "policy:default",
            "class_id": "@signing_policy",
            "name": "Default Policy",
            "class_pattern": "*",
            "require_user": false,
            "require_agent": false,
            "stamp_created_by": true,
            "stamp_updated_by": true,
            "audit_enabled": true,
            "audit_include_changes": true
        },
        {
            "id": "policy:system",
            "class_id": "@signing_policy",
            "name": "System Class Policy",
            "class_pattern": "@*",
            "require_user": true,
            "require_agent": false,
            "stamp_created_by": true,
            "stamp_updated_by": true,
            "audit_enabled": true,
            "audit_include_changes": true
        },
        {
            "id": "policy:ai",
            "class_id": "@signing_policy",
            "name": "AI Agent Policy",
            "class_pattern": "ai:*",
            "require_user": false,
            "require_agent": true,
            "stamp_created_by": true,
            "stamp_updated_by": true,
            "audit_enabled": true,
            "audit_include_changes": true
        }
    ]
}