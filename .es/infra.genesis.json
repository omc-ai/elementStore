{
    "version": "1.0.0",
    "namespace": "infra",
    "description": "Infrastructure classes — VMs, networks, databases, Kubernetes resources. Shared by infrastructure management applications.",
    "classes": [
        {
            "id": "infra:vm",
            "class_id": "@class",
            "name": "Virtual Machine",
            "namespace_id": "infra",
            "extends_id": "core:baseContainer",
            "is_system": false,
            "is_seed": true,
            "icon": "server",
            "color": "#3b82f6",
            "description": "Virtual machine instance",
            "props": [
                {
                    "key": "cpu",
                    "data_type": "integer",
                    "default_value": 2,
                    "description": "Number of vCPUs",
                    "class_id": "@prop_number"
                },
                {
                    "key": "memory",
                    "data_type": "integer",
                    "default_value": 4,
                    "description": "Memory in GB",
                    "class_id": "@prop_number"
                },
                {
                    "key": "disk",
                    "data_type": "integer",
                    "default_value": 40,
                    "description": "Disk size in GB",
                    "class_id": "@prop_number"
                },
                {
                    "key": "os",
                    "data_type": "string",
                    "default_value": "ubuntu-22.04",
                    "description": "Operating system",
                    "options": {
                        "values": [
                            "ubuntu-22.04",
                            "debian-12",
                            "centos-9",
                            "windows-2022"
                        ]
                    },
                    "class_id": "@prop_string"
                },
                {
                    "key": "provider",
                    "data_type": "string",
                    "description": "Cloud provider ID",
                    "class_id": "@prop_string"
                }
            ],
            "defaults": {
                "isServerLinkable": true,
                "cpu": 2,
                "memory": 4,
                "disk": 40,
                "os": "ubuntu-22.04",
                "size": {
                    "width": 300,
                    "height": 250,
                    "depth": 80
                },
                "canvasElement": {
                    "icon": "server",
                    "color": "#3b82f6",
                    "shape": "rounded-rect",
                    "labelPosition": "bottom"
                }
            }
        },
        {
            "id": "infra:service",
            "class_id": "@class",
            "name": "Service",
            "namespace_id": "infra",
            "extends_id": "core:baseElement",
            "is_system": false,
            "is_seed": true,
            "icon": "box",
            "color": "#10b981",
            "description": "Service running on infrastructure",
            "props": [
                {
                    "key": "port",
                    "data_type": "integer",
                    "default_value": 80,
                    "description": "Service port",
                    "class_id": "@prop_number"
                },
                {
                    "key": "protocol",
                    "data_type": "string",
                    "default_value": "http",
                    "description": "Protocol",
                    "options": {
                        "values": [
                            "tcp",
                            "udp",
                            "http",
                            "https",
                            "grpc"
                        ]
                    },
                    "class_id": "@prop_string"
                },
                {
                    "key": "healthCheck",
                    "data_type": "string",
                    "description": "Health check endpoint",
                    "class_id": "@prop_string"
                }
            ],
            "defaults": {
                "port": 80,
                "protocol": "http",
                "canvasElement": {
                    "icon": "box",
                    "color": "#10b981",
                    "shape": "circle",
                    "labelPosition": "bottom"
                }
            }
        },
        {
            "id": "infra:network",
            "class_id": "@class",
            "name": "Network",
            "namespace_id": "infra",
            "extends_id": "core:baseContainer",
            "is_system": false,
            "is_seed": true,
            "icon": "network",
            "color": "#8b5cf6",
            "description": "Virtual network",
            "props": [
                {
                    "key": "cidr",
                    "data_type": "string",
                    "default_value": "10.0.0.0/16",
                    "description": "CIDR block",
                    "class_id": "@prop_string"
                },
                {
                    "key": "isPublic",
                    "data_type": "boolean",
                    "default_value": false,
                    "description": "Has public IP access",
                    "class_id": "@prop_boolean"
                }
            ],
            "defaults": {
                "cidr": "10.0.0.0/16",
                "isPublic": false,
                "size": {
                    "width": 400,
                    "height": 300,
                    "depth": 80
                },
                "canvasElement": {
                    "icon": "network",
                    "color": "#8b5cf6",
                    "shape": "rect",
                    "labelPosition": "top"
                }
            }
        },
        {
            "id": "infra:database",
            "class_id": "@class",
            "name": "Database",
            "namespace_id": "infra",
            "extends_id": "core:baseElement",
            "is_system": false,
            "is_seed": true,
            "icon": "database",
            "color": "#f59e0b",
            "description": "Database instance",
            "props": [
                {
                    "key": "engine",
                    "data_type": "string",
                    "default_value": "postgresql",
                    "description": "Database engine",
                    "options": {
                        "values": [
                            "postgresql",
                            "mysql",
                            "mongodb",
                            "redis",
                            "elasticsearch"
                        ]
                    },
                    "class_id": "@prop_string"
                },
                {
                    "key": "version",
                    "data_type": "string",
                    "default_value": "15",
                    "description": "Engine version",
                    "class_id": "@prop_string"
                },
                {
                    "key": "storage",
                    "data_type": "integer",
                    "default_value": 20,
                    "description": "Storage size in GB",
                    "class_id": "@prop_number"
                }
            ],
            "defaults": {
                "engine": "postgresql",
                "version": "15",
                "storage": 20,
                "canvasElement": {
                    "icon": "database",
                    "color": "#f59e0b",
                    "shape": "rounded-rect",
                    "labelPosition": "bottom"
                }
            }
        },
        {
            "id": "infra:loadbalancer",
            "class_id": "@class",
            "name": "Load Balancer",
            "namespace_id": "infra",
            "extends_id": "core:baseElement",
            "is_system": false,
            "is_seed": true,
            "icon": "split",
            "color": "#ec4899",
            "description": "Load balancer for traffic distribution",
            "props": [
                {
                    "key": "algorithm",
                    "data_type": "string",
                    "default_value": "round-robin",
                    "description": "Load balancing algorithm",
                    "options": {
                        "values": [
                            "round-robin",
                            "least-connections",
                            "ip-hash"
                        ]
                    },
                    "class_id": "@prop_string"
                },
                {
                    "key": "healthCheckPath",
                    "data_type": "string",
                    "default_value": "/health",
                    "description": "Health check path",
                    "class_id": "@prop_string"
                }
            ],
            "defaults": {
                "algorithm": "round-robin",
                "healthCheckPath": "/health",
                "canvasElement": {
                    "icon": "split",
                    "color": "#ec4899",
                    "shape": "diamond",
                    "labelPosition": "bottom"
                }
            }
        },
        {
            "id": "infra:k8sCluster",
            "class_id": "@class",
            "name": "Kubernetes Cluster",
            "namespace_id": "infra",
            "extends_id": "core:baseContainer",
            "is_system": false,
            "is_seed": true,
            "icon": "boxes",
            "color": "#326CE5",
            "description": "Kubernetes cluster with master and worker nodes",
            "props": [
                {
                    "key": "clusterTag",
                    "data_type": "string",
                    "description": "Cluster tag for provider identification (e.g. cluster-prod)",
                    "class_id": "@prop_string"
                },
                {
                    "key": "version",
                    "data_type": "string",
                    "default_value": "1.30",
                    "description": "Kubernetes version",
                    "class_id": "@prop_string"
                },
                {
                    "key": "provider",
                    "data_type": "string",
                    "default_value": "Self-managed",
                    "description": "Kubernetes provider",
                    "options": {
                        "values": [
                            "EKS",
                            "GKE",
                            "AKS",
                            "Self-managed",
                            "K3s",
                            "Minikube",
                            "Kamatera"
                        ]
                    },
                    "class_id": "@prop_string"
                },
                {
                    "key": "region",
                    "data_type": "string",
                    "description": "Deployment region or datacenter",
                    "class_id": "@prop_string"
                },
                {
                    "key": "cni",
                    "data_type": "string",
                    "default_value": "Calico",
                    "description": "Container Network Interface plugin",
                    "options": {
                        "values": [
                            "Calico",
                            "Flannel",
                            "Cilium",
                            "WeaveNet"
                        ]
                    },
                    "class_id": "@prop_string"
                },
                {
                    "key": "podCidr",
                    "data_type": "string",
                    "default_value": "10.244.0.0/16",
                    "description": "Pod network CIDR",
                    "class_id": "@prop_string"
                },
                {
                    "key": "serviceCidr",
                    "data_type": "string",
                    "default_value": "10.96.0.0/12",
                    "description": "Service network CIDR",
                    "class_id": "@prop_string"
                },
                {
                    "key": "linkedClusterId",
                    "data_type": "string",
                    "description": "Linked remote cluster ID (from provider API)",
                    "class_id": "@prop_string"
                },
                {
                    "key": "linkedProvider",
                    "data_type": "string",
                    "description": "Provider config ID this cluster is linked to",
                    "class_id": "@prop_string"
                },
                {
                    "key": "highAvailability",
                    "data_type": "boolean",
                    "default_value": false,
                    "description": "Multi-master HA setup",
                    "class_id": "@prop_boolean"
                }
            ],
            "defaults": {
                "isK8sLinkable": true,
                "version": "1.30",
                "provider": "Self-managed",
                "cni": "Calico",
                "podCidr": "10.244.0.0/16",
                "serviceCidr": "10.96.0.0/12",
                "highAvailability": false,
                "size": {
                    "width": 500,
                    "height": 400,
                    "depth": 100
                },
                "canvasElement": {
                    "icon": "boxes",
                    "color": "#326CE5",
                    "shape": "rounded-rect",
                    "labelPosition": "top"
                }
            },
            "default_children": [
                {
                    "class_id": "infra:k8sNode",
                    "name": "Master Node",
                    "role": "master",
                    "cpu": 2,
                    "memory": 4,
                    "disk": 50,
                    "os": "ubuntu-22.04"
                },
                {
                    "class_id": "infra:k8sNodepool",
                    "name": "Default Pool",
                    "poolName": "default",
                    "nodeCount": 2,
                    "default_children": [
                        {
                            "class_id": "infra:k8sNode",
                            "name": "Worker 1",
                            "role": "worker",
                            "cpu": 2,
                            "memory": 4,
                            "disk": 50,
                            "os": "ubuntu-22.04"
                        },
                        {
                            "class_id": "infra:k8sNode",
                            "name": "Worker 2",
                            "role": "worker",
                            "cpu": 2,
                            "memory": 4,
                            "disk": 50,
                            "os": "ubuntu-22.04"
                        }
                    ]
                }
            ]
        },
        {
            "id": "infra:k8sNodepool",
            "class_id": "@class",
            "name": "Node Pool",
            "namespace_id": "infra",
            "extends_id": "core:baseContainer",
            "is_system": false,
            "is_seed": true,
            "icon": "layers",
            "color": "#4F46E5",
            "description": "Group of worker nodes with shared configuration",
            "props": [
                {
                    "key": "poolName",
                    "data_type": "string",
                    "description": "Pool name for tagging and identification",
                    "class_id": "@prop_string"
                },
                {
                    "key": "nodeCount",
                    "data_type": "integer",
                    "default_value": 2,
                    "description": "Desired node count",
                    "class_id": "@prop_number"
                },
                {
                    "key": "minNodes",
                    "data_type": "integer",
                    "default_value": 1,
                    "description": "Minimum nodes for autoscaling",
                    "class_id": "@prop_number"
                },
                {
                    "key": "maxNodes",
                    "data_type": "integer",
                    "default_value": 10,
                    "description": "Maximum nodes for autoscaling",
                    "class_id": "@prop_number"
                },
                {
                    "key": "autoScaling",
                    "data_type": "boolean",
                    "default_value": true,
                    "description": "Enable cluster autoscaler",
                    "class_id": "@prop_boolean"
                },
                {
                    "key": "instanceType",
                    "data_type": "string",
                    "description": "Instance type or CPU spec (e.g. 2B, t3.medium)",
                    "class_id": "@prop_string"
                },
                {
                    "key": "labels",
                    "data_type": "object",
                    "default_value": {},
                    "description": "Kubernetes node labels applied to pool nodes",
                    "class_id": "@prop_object"
                },
                {
                    "key": "taints",
                    "data_type": "object",
                    "is_array": true,
                    "description": "Kubernetes node taints",
                    "class_id": "@prop_object"
                }
            ],
            "defaults": {
                "nodeCount": 2,
                "minNodes": 1,
                "maxNodes": 10,
                "autoScaling": true,
                "canvasElement": {
                    "icon": "layers",
                    "color": "#4F46E5",
                    "shape": "rounded-rect",
                    "labelPosition": "top"
                }
            }
        },
        {
            "id": "infra:k8sNode",
            "class_id": "@class",
            "name": "K8s Node",
            "namespace_id": "infra",
            "extends_id": "infra:vm",
            "is_system": false,
            "is_seed": true,
            "icon": "hard-drive",
            "color": "#326CE5",
            "description": "Kubernetes node - a VM serving as master or worker in a cluster",
            "props": [
                {
                    "key": "role",
                    "data_type": "string",
                    "default_value": "worker",
                    "description": "Node role in the cluster",
                    "options": {
                        "values": [
                            "master",
                            "worker"
                        ]
                    },
                    "class_id": "@prop_string"
                },
                {
                    "key": "kubeletVersion",
                    "data_type": "string",
                    "description": "Kubelet version running on this node",
                    "class_id": "@prop_string"
                },
                {
                    "key": "nodeLabels",
                    "data_type": "object",
                    "default_value": {},
                    "description": "Kubernetes labels on this node",
                    "class_id": "@prop_object"
                },
                {
                    "key": "nodeConditions",
                    "data_type": "object",
                    "default_value": {},
                    "description": "Node conditions (Ready, MemoryPressure, etc.)",
                    "class_id": "@prop_object"
                }
            ],
            "defaults": {
                "role": "worker",
                "cpu": 2,
                "memory": 4,
                "disk": 50,
                "os": "ubuntu-22.04",
                "isServerLinkable": true,
                "canvasElement": {
                    "icon": "hard-drive",
                    "color": "#326CE5",
                    "shape": "rounded-rect",
                    "labelPosition": "bottom"
                }
            }
        },
        {
            "id": "infra:k8sNamespace",
            "class_id": "@class",
            "name": "K8s Namespace",
            "namespace_id": "infra",
            "extends_id": "core:baseContainer",
            "is_system": false,
            "is_seed": true,
            "icon": "folder-open",
            "color": "#7C3AED",
            "description": "Kubernetes namespace for workload isolation",
            "props": [
                {
                    "key": "resourceQuota",
                    "data_type": "boolean",
                    "default_value": false,
                    "description": "Whether resource quotas are enforced",
                    "class_id": "@prop_boolean"
                },
                {
                    "key": "cpuLimit",
                    "data_type": "string",
                    "description": "CPU resource quota limit (e.g. 4000m)",
                    "class_id": "@prop_string"
                },
                {
                    "key": "memoryLimit",
                    "data_type": "string",
                    "description": "Memory resource quota limit (e.g. 8Gi)",
                    "class_id": "@prop_string"
                }
            ],
            "defaults": {
                "resourceQuota": false,
                "canvasElement": {
                    "icon": "folder-open",
                    "color": "#7C3AED",
                    "shape": "rounded-rect",
                    "labelPosition": "top"
                }
            }
        },
        {
            "id": "infra:k8sService",
            "class_id": "@class",
            "name": "K8s Service",
            "namespace_id": "infra",
            "extends_id": "core:baseElement",
            "is_system": false,
            "is_seed": true,
            "icon": "network",
            "color": "#326CE5",
            "description": "Kubernetes service for pod network exposure",
            "props": [
                {
                    "key": "serviceType",
                    "data_type": "string",
                    "default_value": "ClusterIP",
