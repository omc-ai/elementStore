{
    "version": "1.0.0",
    "namespace": "infra",
    "description": "Infrastructure classes — VMs, networks, databases, Kubernetes resources. Shared by infrastructure management applications.",
    "classes": [
        {
            "id": "infra:vm",
            "class_id": "@class",
            "updated_at": "2026-03-29 17:20:49",
            "created_at": "2026-03-29 14:42:46",
            "name": "Virtual Machine",
            "description": "Virtual machine instance",
            "extends_id": "core:baseContainer",
            "props": [
                {
                    "key": "cpu",
                    "data_type": "integer",
                    "default_value": 2,
                    "description": "Number of vCPUs"
                },
                {
                    "key": "memory",
                    "data_type": "integer",
                    "default_value": 4,
                    "description": "Memory in GB"
                },
                {
                    "key": "disk",
                    "data_type": "integer",
                    "default_value": 40,
                    "description": "Disk size in GB"
                },
                {
                    "key": "os",
                    "data_type": "string",
                    "default_value": "ubuntu-22.04",
                    "description": "Operating system",
                    "options": {
                        "values": [
                            "ubuntu-22.04",
                            "debian-12",
                            "centos-9",
                            "windows-2022"
                        ]
                    }
                },
                {
                    "key": "provider",
                    "data_type": "string",
                    "description": "Cloud provider ID"
                }
            ]
        },
        {
            "id": "infra:service",
            "class_id": "@class",
            "updated_at": "2026-03-29 17:20:49",
            "created_at": "2026-03-29 14:42:46",
            "name": "Service",
            "description": "Service running on infrastructure",
            "extends_id": "core:baseElement",
            "props": [
                {
                    "key": "port",
                    "data_type": "integer",
                    "default_value": 80,
                    "description": "Service port"
                },
                {
                    "key": "protocol",
                    "data_type": "string",
                    "default_value": "http",
                    "description": "Protocol",
                    "options": {
                        "values": [
                            "tcp",
                            "udp",
                            "http",
                            "https",
                            "grpc"
                        ]
                    }
                },
                {
                    "key": "healthCheck",
                    "data_type": "string",
                    "description": "Health check endpoint"
                }
            ]
        },
        {
            "id": "infra:network",
            "class_id": "@class",
            "updated_at": "2026-03-29 17:20:49",
            "created_at": "2026-03-29 14:42:46",
            "name": "Network",
            "description": "Virtual network",
            "extends_id": "core:baseContainer",
            "props": [
                {
                    "key": "cidr",
                    "data_type": "string",
                    "default_value": "10.0.0.0/16",
                    "description": "CIDR block"
                },
                {
                    "key": "isPublic",
                    "data_type": "boolean",
                    "default_value": false,
                    "description": "Has public IP access"
                }
            ]
        },
        {
            "id": "infra:database",
            "class_id": "@class",
            "updated_at": "2026-03-29 17:20:48",
            "created_at": "2026-03-29 14:42:46",
            "name": "Database",
            "description": "Database instance",
            "extends_id": "core:baseElement",
            "props": [
                {
                    "key": "engine",
                    "data_type": "string",
                    "default_value": "postgresql",
                    "description": "Database engine",
                    "options": {
                        "values": [
                            "postgresql",
                            "mysql",
                            "mongodb",
                            "redis",
                            "elasticsearch"
                        ]
                    }
                },
                {
                    "key": "version",
                    "data_type": "string",
                    "default_value": "15",
                    "description": "Engine version"
                },
                {
                    "key": "storage",
                    "data_type": "integer",
                    "default_value": 20,
                    "description": "Storage size in GB"
                }
            ]
        },
        {
            "id": "infra:loadbalancer",
            "class_id": "@class",
            "updated_at": "2026-03-29 17:20:49",
            "created_at": "2026-03-29 14:42:46",
            "name": "Load Balancer",
            "description": "Load balancer for traffic distribution",
            "extends_id": "core:baseElement",
            "props": [
                {
                    "key": "algorithm",
                    "data_type": "string",
                    "default_value": "round-robin",
                    "description": "Load balancing algorithm",
                    "options": {
                        "values": [
                            "round-robin",
                            "least-connections",
                            "ip-hash"
                        ]
                    }
                },
                {
                    "key": "healthCheckPath",
                    "data_type": "string",
                    "default_value": "/health",
                    "description": "Health check path"
                }
            ]
        },
        {
            "id": "infra:k8sCluster",
            "class_id": "@class",
            "updated_at": "2026-03-29 17:20:48",
            "created_at": "2026-03-29 14:42:46",
            "name": "Kubernetes Cluster",
            "description": "Kubernetes cluster with master and worker nodes",
            "extends_id": "core:baseContainer",
            "props": [
                {
                    "key": "clusterTag",
                    "data_type": "string",
                    "description": "Cluster tag for provider identification (e.g. cluster-prod)"
                },
                {
                    "key": "version",
                    "data_type": "string",
                    "default_value": "1.30",
                    "description": "Kubernetes version"
                },
                {
                    "key": "provider",
                    "data_type": "string",
                    "default_value": "Self-managed",
                    "description": "Kubernetes provider",
                    "options": {
                        "values": [
                            "EKS",
                            "GKE",
                            "AKS",
                            "Self-managed",
                            "K3s",
                            "Minikube",
                            "Kamatera"
                        ]
                    }
                },
                {
                    "key": "region",
                    "data_type": "string",
                    "description": "Deployment region or datacenter"
                },
                {
                    "key": "cni",
                    "data_type": "string",
                    "default_value": "Calico",
                    "description": "Container Network Interface plugin",
                    "options": {
                        "values": [
                            "Calico",
                            "Flannel",
                            "Cilium",
                            "WeaveNet"
                        ]
                    }
                },
                {
                    "key": "podCidr",
                    "data_type": "string",
                    "default_value": "10.244.0.0/16",
                    "description": "Pod network CIDR"
                },
                {
                    "key": "serviceCidr",
                    "data_type": "string",
                    "default_value": "10.96.0.0/12",
                    "description": "Service network CIDR"
                },
                {
                    "key": "linkedClusterId",
                    "data_type": "string",
                    "description": "Linked remote cluster ID (from provider API)"
                },
                {
                    "key": "linkedProvider",
                    "data_type": "string",
                    "description": "Provider config ID this cluster is linked to"
                },
                {
                    "key": "highAvailability",
                    "data_type": "boolean",
                    "default_value": false,
                    "description": "Multi-master HA setup"
                }
            ]
        },
        {
            "id": "infra:k8sNodepool",
            "class_id": "@class",
            "updated_at": "2026-03-29 17:20:49",
            "created_at": "2026-03-29 14:42:46",
            "name": "Node Pool",
            "description": "Group of worker nodes with shared configuration",
            "extends_id": "core:baseContainer",
            "props": [
                {
                    "key": "poolName",
                    "data_type": "string",
                    "description": "Pool name for tagging and identification"
                },
                {
                    "key": "nodeCount",
                    "data_type": "integer",
                    "default_value": 2,
                    "description": "Desired node count"
                },
                {
                    "key": "minNodes",
                    "data_type": "integer",
                    "default_value": 1,
                    "description": "Minimum nodes for autoscaling"
                },
                {
                    "key": "maxNodes",
                    "data_type": "integer",
                    "default_value": 10,
                    "description": "Maximum nodes for autoscaling"
                },
                {
                    "key": "autoScaling",
                    "data_type": "boolean",
                    "default_value": true,
                    "description": "Enable cluster autoscaler"
                },
                {
                    "key": "instanceType",
                    "data_type": "string",
                    "description": "Instance type or CPU spec (e.g. 2B, t3.medium)"
                },
                {
                    "key": "labels",
                    "data_type": "object",
                    "default_value": [],
                    "description": "Kubernetes node labels applied to pool nodes"
                },
                {
                    "key": "taints",
                    "data_type": "object",
                    "is_array": true,
                    "description": "Kubernetes node taints"
                }
            ]
        },
        {
            "id": "infra:k8sNode",
            "class_id": "@class",
            "updated_at": "2026-03-29 17:20:49",
            "created_at": "2026-03-29 14:42:46",
            "name": "K8s Node",
            "description": "Kubernetes node - a VM serving as master or worker in a cluster",
            "extends_id": "infra:vm",
            "props": [
                {
                    "key": "role",
                    "data_type": "string",
                    "default_value": "worker",
                    "description": "Node role in the cluster",
                    "options": {
                        "values": [
                            "master",
                            "worker"
                        ]
                    }
                },
                {
                    "key": "kubeletVersion",
                    "data_type": "string",
                    "description": "Kubelet version running on this node"
                },
                {
                    "key": "nodeLabels",
                    "data_type": "object",
                    "default_value": [],
                    "description": "Kubernetes labels on this node"
                },
                {
                    "key": "nodeConditions",
                    "data_type": "object",
                    "default_value": [],
                    "description": "Node conditions (Ready, MemoryPressure, etc.)"
                }
            ]
        },
        {
            "id": "infra:k8sNamespace",
            "class_id": "@class",
            "updated_at": "2026-03-29 17:20:49",
            "created_at": "2026-03-29 14:42:46",
            "name": "K8s Namespace",
            "description": "Kubernetes namespace for workload isolation",
            "extends_id": "core:baseContainer",
            "props": [
                {
                    "key": "resourceQuota",
                    "data_type": "boolean",
                    "default_value": false,
                    "description": "Whether resource quotas are enforced"
                },
                {
                    "key": "cpuLimit",
                    "data_type": "string",
                    "description": "CPU resource quota limit (e.g. 4000m)"
                },
                {
                    "key": "memoryLimit",
                    "data_type": "string",
                    "description": "Memory resource quota limit (e.g. 8Gi)"
                }
            ]
        },
        {
            "id": "infra:k8sService",
            "class_id": "@class",
            "updated_at": "2026-03-29 17:20:49",
            "created_at": "2026-03-29 14:42:46",
            "name": "K8s Service",
            "description": "Kubernetes service for pod network exposure",
            "extends_id": "core:baseElement",
            "props": [
                {
                    "key": "serviceType",
                    "data_type": "string",
                    "default_value": "ClusterIP",
                    "description": "Kubernetes service type",
                    "options": {
                        "values": [
                            "ClusterIP",
                            "NodePort",
                            "LoadBalancer",
                            "ExternalName"
                        ]
                    }
                },
                {
                    "key": "port",
                    "data_type": "integer",
                    "default_value": 80,
                    "description": "Service port"
                },
                {
                    "key": "targetPort",
                    "data_type": "integer",
                    "description": "Container target port"
                },
                {
                    "key": "nodePort",
                    "data_type": "integer",
                    "description": "NodePort (30000-32767) when serviceType is NodePort"
                },
                {
                    "key": "protocol",
                    "data_type": "string",
                    "default_value": "TCP",
                    "description": "Protocol",
                    "options": {
                        "values": [
                            "TCP",
                            "UDP"
                        ]
                    }
                },
                {
                    "key": "selector",
                    "data_type": "object",
                    "default_value": [],
                    "description": "Label selector for target pods"
                },
                {
                    "key": "clusterIP",
                    "data_type": "string",
                    "description": "Assigned cluster IP"
                }
            ]
        },
        {
            "id": "infra:k8sIngress",
            "class_id": "@class",
            "updated_at": "2026-03-29 17:20:49",
            "created_at": "2026-03-29 14:42:46",
            "name": "K8s Ingress",
            "description": "Kubernetes ingress for HTTP/HTTPS routing",
            "extends_id": "core:baseElement",
            "props": [
                {
                    "key": "ingressClass",
                    "data_type": "string",
                    "default_value": "nginx",
                    "description": "Ingress controller class",
                    "options": {
                        "values": [
                            "nginx",
                            "traefik",
                            "haproxy",
                            "istio",
                            "kong"
                        ]
                    }
                },
                {
                    "key": "host",
                    "data_type": "string",
                    "description": "Hostname for routing (e.g. app.example.com)"
                },
                {
                    "key": "tlsEnabled",
                    "data_type": "boolean",
                    "default_value": false,
                    "description": "Enable TLS termination"
                },
                {
                    "key": "tlsSecretName",
                    "data_type": "string",
                    "description": "TLS secret name in the namespace"
                },
                {
                    "key": "rules",
                    "data_type": "object",
                    "is_array": true,
                    "description": "Ingress routing rules (path, pathType, serviceName, servicePort)"
                },
                {
                    "key": "annotations",
                    "data_type": "object",
                    "default_value": [],
                    "description": "Ingress annotations"
                }
            ]
        },
        {
            "id": "infra:k8sDeployment",
            "class_id": "@class",
            "updated_at": "2026-03-29 17:20:49",
            "created_at": "2026-03-29 14:42:46",
            "name": "K8s Deployment",
            "description": "Kubernetes deployment managing pod replicas",
            "extends_id": "core:baseContainer",
            "props": [
                {
                    "key": "replicas",
                    "data_type": "integer",
                    "default_value": 1,
                    "description": "Desired pod replica count"
                },
                {
                    "key": "image",
                    "data_type": "string",
                    "description": "Container image (e.g. nginx:latest)"
                },
                {
                    "key": "containerPort",
                    "data_type": "integer",
                    "description": "Container port to expose"
                },
                {
                    "key": "strategy",
                    "data_type": "string",
                    "default_value": "RollingUpdate",
                    "description": "Update strategy",
                    "options": {
                        "values": [
                            "RollingUpdate",
                            "Recreate"
                        ]
                    }
                },
                {
                    "key": "cpuRequest",
                    "data_type": "string",
                    "description": "CPU request (e.g. 100m)"
                },
                {
                    "key": "cpuLimit",
                    "data_type": "string",
                    "description": "CPU limit (e.g. 500m)"
                },
                {
                    "key": "memoryRequest",
                    "data_type": "string",
                    "description": "Memory request (e.g. 128Mi)"
                },
                {
                    "key": "memoryLimit",
                    "data_type": "string",
                    "description": "Memory limit (e.g. 256Mi)"
                },
                {
                    "key": "env",
                    "data_type": "object",
                    "default_value": [],
                    "description": "Environment variables"
                }
            ]
        },
        {
            "id": "infra:k8sConfigMap",
            "class_id": "@class",
            "updated_at": "2026-03-29 17:20:49",
            "created_at": "2026-03-29 14:42:46",
            "name": "K8s ConfigMap",
            "description": "Kubernetes ConfigMap for non-sensitive configuration",
            "extends_id": "core:baseElement",
            "props": [
                {
                    "key": "data",
                    "data_type": "object",
                    "default_value": [],
                    "description": "Key-value configuration data"
                }
            ]
        },
        {
            "id": "infra:k8sSecret",
            "class_id": "@class",
            "updated_at": "2026-03-29 17:20:49",
            "created_at": "2026-03-29 14:42:46",
            "name": "K8s Secret",
            "description": "Kubernetes Secret for sensitive data",
            "extends_id": "core:baseElement",
            "props": [
                {
                    "key": "secretType",
                    "data_type": "string",
                    "default_value": "Opaque",
                    "description": "Secret type",
                    "options": {
                        "values": [
                            "Opaque",
                            "kubernetes.io/tls",
                            "kubernetes.io/dockerconfigjson",
                            "kubernetes.io/service-account-token"
                        ]
                    }
                },
                {
                    "key": "keys",
                    "data_type": "string",
                    "is_array": true,
                    "description": "Secret key names (values are never stored)"
                }
            ]
        },
        {
            "id": "infra:k8sPersistentVolume",
            "class_id": "@class",
            "updated_at": "2026-03-29 17:20:49",
            "created_at": "2026-03-29 14:42:46",
            "name": "K8s Persistent Volume",
            "description": "Kubernetes persistent volume for stateful storage",
            "extends_id": "core:baseElement",
            "props": [
                {
                    "key": "capacity",
                    "data_type": "integer",
                    "default_value": 10,
                    "description": "Storage capacity in GB"
                },
                {
                    "key": "storageClass",
                    "data_type": "string",
                    "description": "Storage class name"
                },
                {
                    "key": "accessMode",
                    "data_type": "string",
                    "default_value": "ReadWriteOnce",
                    "description": "Volume access mode",
                    "options": {
                        "values": [
                            "ReadWriteOnce",
                            "ReadOnlyMany",
                            "ReadWriteMany"
                        ]
                    }
                },
                {
                    "key": "reclaimPolicy",
                    "data_type": "string",
                    "default_value": "Retain",
                    "description": "What happens when PVC is released",
                    "options": {
                        "values": [
                            "Retain",
                            "Delete",
                            "Recycle"
                        ]
                    }
                }
            ]
        }
    ]
}