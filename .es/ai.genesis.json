{
  "version": "1.0.0",
  "namespace": "ai",
  "description": "Shared AI/agent classes — used by aic.sh, cwm-architect, and any application that works with agents, tasks, prompts, decisions.",
  "classes": [
    {
      "id": "ai:agent",
      "class_id": "@class",
      "name": "Agent",
      "description": "An AI agent that can execute tasks, use tools, and make decisions. Extend for project-specific fields.",
      "props": [
        {"key": "name", "data_type": "string", "display_order": 1, "flags": {"required": true}, "class_id": "@prop_string"},
        {"key": "description", "data_type": "string", "editor": {"id": "textarea"}, "display_order": 2, "class_id": "@prop_string"},
        {"key": "title", "data_type": "string", "display_order": 3, "description": "Job title / role", "class_id": "@prop_string"},
        {"key": "prompt", "data_type": "string", "editor": {"id": "code"}, "display_order": 4, "description": "System prompt template", "class_id": "@prop_string"},
        {"key": "tools", "data_type": "relation", "is_array": "indexed", "object_class_id": ["@action"], "display_order": 5, "description": "Actions this agent can execute (tools ARE actions)", "class_id": "@prop_relation"},
        {"key": "domain", "data_type": "string", "is_array": "indexed", "display_order": 6, "description": "Areas of responsibility", "class_id": "@prop_string"},
        {"key": "is_active", "data_type": "boolean", "default_value": true, "display_order": 7, "class_id": "@prop_boolean"},
        {"key": "execution_order", "data_type": "integer", "display_order": 8, "description": "Run sequence (lower = first)", "class_id": "@prop_number"},
        {"key": "model", "data_type": "string", "display_order": 9, "description": "LLM model ID", "class_id": "@prop_string"},
        {"key": "avatar", "data_type": "string", "display_order": 10, "description": "Avatar image URL", "class_id": "@prop_string"},
        {"key": "last_run", "data_type": "string", "display_order": 11, "flags": {"readonly": true}, "class_id": "@prop_string"},
        {"key": "run_count", "data_type": "integer", "default_value": 0, "display_order": 12, "flags": {"readonly": true}, "class_id": "@prop_number"}
      ]
    },
    {
      "id": "ai:task",
      "class_id": "@class",
      "name": "Task",
      "description": "An actionable work item — assigned to agents, tracked through lifecycle.",
      "props": [
        {"key": "name", "data_type": "string", "display_order": 1, "flags": {"required": true}, "class_id": "@prop_string"},
        {"key": "description", "data_type": "string", "editor": {"id": "textarea"}, "display_order": 2, "class_id": "@prop_string"},
        {"key": "priority", "data_type": "string", "display_order": 3, "options": {"values": ["P0", "P1", "P2", "P3"]}, "class_id": "@prop_string"},
        {"key": "status", "data_type": "string", "display_order": 4, "options": {"values": ["open", "in_progress", "blocked", "done", "wont_do"]}, "default_value": "open", "class_id": "@prop_string"},
        {"key": "project", "data_type": "string", "display_order": 5, "class_id": "@prop_string"},
        {"key": "agent_id", "data_type": "relation", "object_class_id": ["ai:agent"], "display_order": 6, "class_id": "@prop_relation"},
        {"key": "round_id", "data_type": "relation", "object_class_id": ["ai:round"], "display_order": 7, "class_id": "@prop_relation"},
        {"key": "source", "data_type": "string", "display_order": 8, "options": {"values": ["manual", "ceo_directive", "roadmap", "agent", "audit", "human_request"]}, "class_id": "@prop_string"},
        {"key": "blocks", "data_type": "relation", "is_array": "indexed", "object_class_id": ["ai:task"], "display_order": 9, "class_id": "@prop_relation"},
        {"key": "blocked_by", "data_type": "relation", "is_array": "indexed", "object_class_id": ["ai:task"], "display_order": 10, "class_id": "@prop_relation"},
        {"key": "step", "data_type": "integer", "display_order": 11, "description": "Execution step number", "class_id": "@prop_number"},
        {"key": "files", "data_type": "string", "is_array": "indexed", "display_order": 12, "class_id": "@prop_string"},
        {"key": "result", "data_type": "string", "editor": {"id": "textarea"}, "display_order": 13, "class_id": "@prop_string"},
        {"key": "started", "data_type": "string", "display_order": 14, "flags": {"readonly": true}, "class_id": "@prop_string"},
        {"key": "completed", "data_type": "string", "display_order": 15, "flags": {"readonly": true}, "class_id": "@prop_string"},
        {"key": "tokens_used", "data_type": "integer", "display_order": 16, "flags": {"readonly": true}, "class_id": "@prop_number"},
        {"key": "commits", "data_type": "string", "is_array": "indexed", "display_order": 17, "flags": {"readonly": true}, "class_id": "@prop_string"}
      ]
    },
    {
      "id": "ai:prompt",
      "class_id": "@class",
      "name": "Prompt",
      "description": "A reusable prompt template with variable substitution.",
      "props": [
        {"key": "name", "data_type": "string", "display_order": 1, "flags": {"required": true}, "class_id": "@prop_string"},
        {"key": "description", "data_type": "string", "display_order": 2, "class_id": "@prop_string"},
        {"key": "type", "data_type": "string", "display_order": 3, "options": {"values": ["shared_context", "system", "first_run", "every_run", "review", "domain", "task"]}, "class_id": "@prop_string"},
        {"key": "template", "data_type": "string", "editor": {"id": "code"}, "display_order": 4, "description": "Prompt text with {{variable}} placeholders", "class_id": "@prop_string"},
        {"key": "variables", "data_type": "string", "is_array": "indexed", "display_order": 5, "class_id": "@prop_string"},
        {"key": "agent_id", "data_type": "relation", "object_class_id": ["ai:agent"], "display_order": 6, "description": "Owner agent (null = shared)", "class_id": "@prop_relation"},
        {"key": "version", "data_type": "string", "display_order": 7, "class_id": "@prop_string"}
      ]
    },
    {
      "id": "ai:decision",
      "class_id": "@class",
      "name": "Decision",
      "description": "A recorded decision with rationale and assignment.",
      "props": [
        {"key": "name", "data_type": "string", "display_order": 1, "flags": {"required": true}, "class_id": "@prop_string"},
        {"key": "topic", "data_type": "string", "display_order": 2, "class_id": "@prop_string"},
        {"key": "decision", "data_type": "string", "editor": {"id": "textarea"}, "display_order": 3, "class_id": "@prop_string"},
        {"key": "rationale", "data_type": "string", "editor": {"id": "textarea"}, "display_order": 4, "class_id": "@prop_string"},
        {"key": "priority", "data_type": "string", "display_order": 5, "options": {"values": ["P0", "P1", "P2", "P3"]}, "class_id": "@prop_string"},
        {"key": "assigned_agents", "data_type": "relation", "is_array": "indexed", "object_class_id": ["ai:agent"], "display_order": 6, "class_id": "@prop_relation"},
        {"key": "round_id", "data_type": "relation", "object_class_id": ["ai:round"], "display_order": 7, "class_id": "@prop_relation"},
        {"key": "implemented", "data_type": "boolean", "default_value": false, "display_order": 8, "class_id": "@prop_boolean"},
        {"key": "owner_approved", "data_type": "boolean", "default_value": false, "display_order": 9, "class_id": "@prop_boolean"},
        {"key": "preference_id", "data_type": "relation", "object_class_id": ["ai:preference"], "display_order": 10, "class_id": "@prop_relation"}
      ]
    },
    {
      "id": "ai:preference",
      "class_id": "@class",
      "name": "Preference",
      "description": "A learned preference rule. Confidence grows with confirmation.",
      "props": [
        {"key": "name", "data_type": "string", "display_order": 1, "flags": {"required": true}, "class_id": "@prop_string"},
        {"key": "category", "data_type": "string", "display_order": 2, "options": {"values": ["security", "architecture", "product", "design", "marketing", "finance", "devops", "content", "general"]}, "class_id": "@prop_string"},
        {"key": "rule", "data_type": "string", "editor": {"id": "textarea"}, "display_order": 3, "class_id": "@prop_string"},
        {"key": "confidence", "data_type": "string", "display_order": 4, "options": {"values": ["low", "medium", "high", "autonomous"]}, "default_value": "low", "class_id": "@prop_string"},
        {"key": "times_confirmed", "data_type": "integer", "default_value": 0, "display_order": 5, "class_id": "@prop_number"},
        {"key": "applies_to", "data_type": "relation", "is_array": "indexed", "object_class_id": ["ai:agent"], "display_order": 6, "class_id": "@prop_relation"},
        {"key": "learned_from", "data_type": "string", "display_order": 7, "class_id": "@prop_string"},
        {"key": "overridden", "data_type": "boolean", "default_value": false, "display_order": 8, "class_id": "@prop_boolean"}
      ]
    },
    {
      "id": "ai:round",
      "class_id": "@class",
      "name": "Round",
      "description": "An execution round — one cycle of agents running sequentially.",
      "props": [
        {"key": "name", "data_type": "string", "display_order": 1, "class_id": "@prop_string"},
        {"key": "round_number", "data_type": "integer", "display_order": 2, "class_id": "@prop_number"},
        {"key": "session_id", "data_type": "string", "display_order": 3, "class_id": "@prop_string"},
        {"key": "started", "data_type": "string", "display_order": 4, "class_id": "@prop_string"},
        {"key": "completed", "data_type": "string", "display_order": 5, "class_id": "@prop_string"},
        {"key": "agents_completed", "data_type": "relation", "is_array": "indexed", "object_class_id": ["ai:agent"], "display_order": 6, "class_id": "@prop_relation"},
        {"key": "decisions_made", "data_type": "integer", "default_value": 0, "display_order": 7, "class_id": "@prop_number"},
        {"key": "summary", "data_type": "string", "editor": {"id": "textarea"}, "display_order": 8, "class_id": "@prop_string"},
        {"key": "all_tasks_complete", "data_type": "boolean", "default_value": false, "display_order": 9, "class_id": "@prop_boolean"}
      ]
    }
  ]
}
