{
    "version": "1.0.0",
    "namespace": "auth",
    "source_project": "auth-service",
    "description": "Auth-service data models — users, roles, modules, permissions, and refresh tokens. Classes mirror the auth-service internal schema; instances backed by auth-service API via crud_provider.",
    "classes": [
        {
            "name": "Auth Role",
            "description": "Named role with permissions. Assigned to users per app.",
            "extends_id": "core:atomObj",
            "props": [
                {
                    "key": "role_name",
                    "data_type": "string",
                    "display_order": 1,
                    "class_id": "@prop_string",
                    "flags": {
                        "required": true
                    },
                    "id": "auth:role.role_name"
                },
                {
                    "key": "app_id",
                    "data_type": "relation",
                    "display_order": 2,
                    "class_id": "@prop_relation",
                    "options": {
                        "class_id": "@app"
                    },
                    "id": "auth:role.app_id"
                },
                {
                    "key": "permissions",
                    "data_type": "relation",
                    "is_array": "indexed",
                    "display_order": 3,
                    "class_id": "@prop_relation",
                    "options": {
                        "class_id": "auth:permission"
                    },
                    "id": "auth:role.permissions"
                },
                {
                    "key": "is_system",
                    "data_type": "boolean",
                    "display_order": 4,
                    "class_id": "@prop_boolean",
                    "id": "auth:role.is_system"
                },
                {
                    "key": "is_default",
                    "data_type": "boolean",
                    "display_order": 5,
                    "class_id": "@prop_boolean",
                    "id": "auth:role.is_default"
                }
            ],
            "is_system": true,
            "id": "auth:role",
            "class_id": "@class",
            "@state": {
                "version": "3a297baf861c6e8c8b983c9a08019fd0"
            }
        },
        {
            "name": "Auth Permission",
            "description": "Single permission: module + action. Grouped into roles.",
            "extends_id": "core:atomObj",
            "props": [
                {
                    "key": "module",
                    "data_type": "string",
                    "display_order": 1,
                    "class_id": "@prop_string",
                    "flags": {
                        "required": true
                    },
                    "id": "auth:permission.module"
                },
                {
                    "key": "action",
                    "data_type": "string",
                    "display_order": 2,
                    "class_id": "@prop_string",
                    "flags": {
                        "required": true
                    },
                    "id": "auth:permission.action"
                },
                {
                    "key": "app_id",
                    "data_type": "relation",
                    "display_order": 3,
                    "class_id": "@prop_relation",
                    "options": {
                        "class_id": "@app"
                    },
                    "id": "auth:permission.app_id"
                }
            ],
            "is_system": true,
            "id": "auth:permission",
            "class_id": "@class",
            "@state": {
                "version": "3a297baf861c6e8c8b983c9a0801af94"
            }
        },
        {
            "name": "Auth Module",
            "description": "Feature module within an app. Groups permissions.",
            "extends_id": "core:atomObj",
            "props": [
                {
                    "key": "module_name",
                    "data_type": "string",
                    "display_order": 1,
                    "class_id": "@prop_string",
                    "flags": {
                        "required": true
                    },
                    "id": "auth:module.module_name"
                },
                {
                    "key": "app_id",
                    "data_type": "relation",
                    "display_order": 2,
                    "class_id": "@prop_relation",
                    "options": {
                        "class_id": "@app"
                    },
                    "id": "auth:module.app_id"
                },
                {
                    "key": "permissions",
                    "data_type": "relation",
                    "is_array": "indexed",
                    "display_order": 3,
                    "class_id": "@prop_relation",
                    "options": {
                        "class_id": "auth:permission",
                        "foreign_key": "module"
                    },
                    "id": "auth:module.permissions"
                }
            ],
            "is_system": true,
            "id": "auth:module",
            "class_id": "@class",
            "@state": {
                "version": "3a297baf861c6e8c8b983c9a0801b8c6"
            }
        },
        {
            "name": "Credential",
            "description": "Secure storage for API keys, tokens, secrets. Server-only fields for sensitive data.",
            "extends_id": "core:atomObj",
            "props": [
                {
                    "key": "credential_name",
                    "data_type": "string",
                    "display_order": 1,
                    "class_id": "@prop_string",
                    "flags": {
                        "required": true
                    },
                    "id": "auth:credential.credential_name"
                },
                {
                    "key": "provider",
                    "data_type": "string",
                    "display_order": 2,
                    "class_id": "@prop_string",
                    "id": "auth:credential.provider"
                },
                {
                    "key": "user_id",
                    "data_type": "relation",
                    "display_order": 3,
                    "class_id": "@prop_relation",
                    "options": {
                        "class_id": "@user"
                    },
                    "id": "auth:credential.user_id"
                },
                {
                    "key": "key",
                    "data_type": "string",
                    "display_order": 4,
                    "class_id": "@prop_string",
                    "flags": {
                        "server_only": true
                    },
                    "id": "auth:credential.key"
                },
                {
                    "key": "secret",
                    "data_type": "string",
                    "display_order": 5,
                    "class_id": "@prop_string",
                    "flags": {
                        "server_only": true
                    },
                    "id": "auth:credential.secret"
                },
                {
                    "key": "token",
                    "data_type": "string",
                    "display_order": 6,
                    "class_id": "@prop_string",
                    "flags": {
                        "server_only": true
                    },
                    "id": "auth:credential.token"
                },
                {
                    "key": "metadata",
                    "data_type": "object",
                    "display_order": 7,
                    "class_id": "@prop_object",
                    "id": "auth:credential.metadata"
                },
                {
                    "key": "expires_at",
                    "data_type": "string",
                    "display_order": 8,
                    "class_id": "@prop_string",
                    "id": "auth:credential.expires_at"
                },
                {
                    "key": "is_active",
                    "data_type": "boolean",
                    "display_order": 9,
                    "class_id": "@prop_boolean",
                    "id": "auth:credential.is_active"
                }
            ],
            "is_system": true,
            "id": "auth:credential",
            "class_id": "@class",
            "@state": {
                "version": "3a297baf861c6e8c8b983c9a0801b92f"
            }
        },
        {
            "id": "auth:signing_policy",
            "class_id": "@class",
            "name": "Signing Policy",
            "description": "Per-scope mutation signing configuration. Defines which identity fields are stamped on mutations and whether audit logging is required. One policy per class pattern; the default policy ('*') applies universally.",
            "is_system": true,
            "is_seed": true,
            "namespace_id": "signing",
            "props": [
                {
                    "key": "name",
                    "label": "Name",
                    "description": "Human-readable policy name.",
                    "data_type": "string",
                    "display_order": 1,
                    "class_id": "@prop_string",
                    "flags": {
                        "required": true
                    }
                },
                {
                    "key": "class_pattern",
                    "label": "Class Pattern",
                    "description": "Glob/regex pattern of class IDs this policy applies to. '*' = all classes. Examples: 'ai:*', '@action', 'user'.",
                    "data_type": "string",
                    "display_order": 2,
                    "class_id": "@prop_string",
                    "options": {
                        "default": "*"
                    }
                },
                {
                    "key": "require_user",
                    "label": "Require User",
                    "description": "Reject mutations that have no user_id in context. Enforces authenticated writes.",
                    "data_type": "boolean",
                    "display_order": 3,
                    "class_id": "@prop_boolean",
                    "options": {
                        "default": false
                    }
                },
                {
                    "key": "require_agent",
                    "label": "Require Agent",
                    "description": "Reject mutations that have no agent_id in context. Enforces agent attribution.",
                    "data_type": "boolean",
                    "display_order": 4,
                    "class_id": "@prop_boolean",
                    "options": {
                        "default": false
                    }
                },
                {
                    "key": "stamp_created_by",
                    "label": "Stamp created_by",
                    "description": "Automatically stamp created_by (user_id) and created_by_agent (agent_id) on object creation.",
                    "data_type": "boolean",
                    "display_order": 5,
                    "class_id": "@prop_boolean",
                    "options": {
                        "default": true
                    }
                },
                {
                    "key": "stamp_updated_by",
                    "label": "Stamp updated_by",
                    "description": "Automatically stamp updated_by (user_id) and updated_by_agent (agent_id) on every update.",
                    "data_type": "boolean",
                    "display_order": 6,
                    "class_id": "@prop_boolean",
                    "options": {
                        "default": true
                    }
                },
                {
                    "key": "audit_enabled",
                    "label": "Audit Enabled",
                    "description": "Write an @audit_entry record for every matching mutation (create, update, delete).",
                    "data_type": "boolean",
                    "display_order": 7,
                    "class_id": "@prop_boolean",
                    "options": {
                        "default": true
                    }
                },
                {
                    "key": "audit_include_changes",
                    "label": "Include Changes in Audit",
                    "description": "Store the full field-level diff ({old, new} per changed field) in the audit entry. Disable for high-volume classes to reduce storage.",
                    "data_type": "boolean",
                    "display_order": 8,
                    "class_id": "@prop_boolean",
                    "options": {
                        "default": true
                    }
                }
            ]
        },
        {
            "id": "auth:audit_entry",
            "class_id": "@class",
            "name": "Audit Entry",
            "description": "Immutable audit record written after every object mutation (create, update, delete). Captures who made the change, when, and what changed. Never deleted — append-only audit trail.",
            "is_system": true,
            "is_seed": false,
            "namespace_id": "signing",
            "props": [
                {
                    "key": "target_class_id",
                    "label": "Target Class",
                    "description": "The class_id of the object that was mutated.",
                    "data_type": "string",
                    "display_order": 1,
                    "class_id": "@prop_string",
                    "flags": {
                        "required": true,
                        "readonly": true
                    }
                },
                {
                    "key": "object_id",
                    "label": "Object ID",
                    "description": "The id of the object that was mutated.",
                    "data_type": "string",
                    "display_order": 2,
                    "class_id": "@prop_string",
                    "flags": {
                        "required": true,
                        "readonly": true
                    }
                },
                {
                    "key": "mutation_type",
                    "label": "Mutation Type",
                    "description": "Type of mutation: create | update | delete.",
                    "data_type": "string",
                    "display_order": 3,
                    "class_id": "@prop_string",
                    "flags": {
                        "required": true,
                        "readonly": true
                    },
                    "options": {
                        "values": [
                            "create",
                            "update",
                            "delete"
                        ]
                    }
                },
                {
                    "key": "user_id",
                    "label": "User ID",
                    "description": "ID of the authenticated user who triggered the mutation. Null for system/anonymous writes.",
                    "data_type": "string",
                    "display_order": 4,
                    "class_id": "@prop_string",
                    "flags": {
                        "readonly": true
                    }
                },
                {
                    "key": "agent_id",
                    "label": "Agent ID",
                    "description": "ID of the agent (AI or automated system) that performed the mutation. Null for direct user writes.",
                    "data_type": "string",
                    "display_order": 5,
                    "class_id": "@prop_string",
                    "flags": {
                        "readonly": true
                    }
                },
                {
                    "key": "session_id",
                    "label": "Session ID",
                    "description": "Optional session/request correlation ID for grouping related mutations.",
                    "data_type": "string",
                    "display_order": 6,
                    "class_id": "@prop_string",
                    "flags": {
                        "readonly": true
                    }
                },
                {
                    "key": "signed_at",
                    "label": "Signed At",
                    "description": "ISO 8601 timestamp when this audit entry was written (server time).",
                    "data_type": "datetime",
                    "display_order": 7,
                    "class_id": "@prop_datetime",
                    "flags": {
                        "required": true,
                        "readonly": true
                    }
                },
                {
                    "key": "changes",
                    "label": "Changes",
                    "description": "Field-level diff: {field_key: {old: ..., new: ...}}. Only populated when audit_include_changes is true on the active policy.",
                    "data_type": "object",
                    "display_order": 8,
                    "class_id": "@prop_object",
                    "flags": {
                        "readonly": true
                    }
                },
                {
                    "key": "policy_id",
                    "label": "Policy ID",
                    "description": "ID of the @signing_policy that matched this mutation.",
                    "data_type": "string",
                    "display_order": 9,
                    "class_id": "@prop_string",
                    "flags": {
                        "readonly": true
                    }
                }
            ]
        }
    ]
}