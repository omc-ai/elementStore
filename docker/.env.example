# ElementStore Docker Configuration
# Copy to .env and customize as needed

# Timezone
TZ=UTC

# PHP API Server
PHP_PORT=8080

# CouchDB — CHANGE credentials in production
COUCHDB_PORT=5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Environment: development | production
ES_ENV=development

# CORS — comma-separated allowed origins (leave empty for restrictive default)
CORS_ALLOWED_ORIGINS=http://arc3d.master.local,http://localhost:8369,http://localhost:3000,http://localhost:5173

# Rate limiting (requests per window per IP)
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=60
